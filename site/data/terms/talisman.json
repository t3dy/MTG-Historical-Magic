"colors": [], "img_small": "https://cards.scryfall.io/small/front/6/b/6b6307f3-bc63-463c-8ffc-a8b8b829e5d7.jpg?1782705153", "img_normal": "https://cards.scryfall.io/normal/front/6/b/6b6307f3-bc63-463c-8ffc-a8b8b829e5d7.jpg?1782705153", "scryfall_uri": "https://scryfall.com/card/c21/258/pristine-talisman?utm_source=api", "local": "img/talisman/1b3d7fce-e9fe-4176-9d9a-472415826cdd.jpg"}], "flavor_snippets": [], "mechanics_snippets": [{"card": "Trickster's Talisman", "set": "AFR", "html": "Invoke Duplicity — Equipped creature gets +1/+1 and has &quot;Whenever this creature deals combat damage to a player, you may sacrifice Trickster&#x27;s <mark>Talisman</mark>. If you do, create a token that&#x27;s a copy of this creature.&quot;\nEquip {2}"}, {"card": "Bloodsprout Talisman", "set": "YDMU", "html": "Bloodsprout <mark>Talisman</mark> enters tapped.\n{T}, Pay 1 life: Choose a nonland card in your hand. It perpetually gains &quot;This spell costs {1} less to cast.&quot;"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/b/3/b356ee36-1c62-4097-87d7-fef6a6dad067.jpg?1782682486", "small": "https://cards.scryfall.io/small/front/b/3/b356ee36-1c62-4097-87d7-fef6a6dad067.jpg?1782682486", "card": "Talisman of Progress"}}