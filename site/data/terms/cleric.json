{"slug": "cleric", "root": "cleric", "category": "profession", "gloss": "a divine spellcaster", "definition": "A cleric is a divine spellcaster — one whose magic flows from a god or a sacred office rather than from arcane study. The word sits exactly on the border of religion and magic.", "history": "*Cleric* comes from Late Latin *clericus*, from Greek *klērikos*, from *klēros*, 'a lot, an inheritance': the clergy are 'God's lot,' his portion. That lot-metaphor is the very one hidden in *sorcerer* (a caster of lots) — pointed, here, in the opposite, holy direction. Dungeons & Dragons made the cleric a healing spellcaster class; Magic's Clerics skew white and black, the colors of order and sacrifice.", "def_sources": [{"label": "Etymonline, s.v. cleric", "where": "Etymology reference"}], "commentary": null, "commentary_sources": [], "is_keyword": false, "etymology": {"origin": "Late Latin clericus ← Greek klērikos, from klēros ‘a lot, inheritance’", "first": "OE cleric / clerc", "note": "The clergy are ‘God’s lot’ (klēros) — the same fate/lot metaphor that hides inside ‘sorcerer,’ pointed the opposite, holy direction.", "hook": "Cleric vs sorcerer: two casters of the same ‘lot.’", "lang": "Greek"}, "essay": null, "sources": ["Etymonline (Douglas Harper)", "Wiktionary", "classical lexica (Lewis & Short, LSJ, Bosworth–Toller)", "Ted's historical-magic DBs (WitchcraftStudiesDB, AgrippaDOP, MedievalMagicDB)"], "stats": {"flavor_total": 26, "oracle_total": 112, "in_flavor_cards": 25, "in_oracle_cards": 102, "name_match_count": 28, "by_variant": {"cleric": 115, "clerics": 23}, "first_year": 2001, "colors": {"W": 75, "B": 48, "U": 18, "R": 11, "C": 9, "G": 7}, "by_year": {"2001": 1, "2002": 14, "2003": 9, "2008": 1, "2009": 3, "2010": 2, "2012": 1, "2013": 1, "2014": 3, "2015": 2, "2016": 2, "2017": 6, "2018": 2, "2019": 1, "2020": 40, "2021": 7, "2022": 24, "2023": 7, "2024": 7, "2025": 5, "2026": 2}}, "cards": [{"id": "7330201a-41ff-44bf-a623-2ed062878c58", "name": "Fallen Cleric", "set": "ONS", "set_name": "Onslaught", "released": "2002-10-07", "type_line": "Creature — Zombie Cleric", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/7/6/7652dc61-9170-4895-a0bf-c32a1ee0350e.jpg?1782719156", "img_normal": "https://cards.scryfall.io/normal/front/7/6/7652dc61-9170-4895-a0bf-c32a1ee0350e.jpg?1782719156", "scryfall_uri": "https://scryfall.com/card/ons/145/fallen-cleric?utm_source=api", "local": "img/cleric/7330201a-41ff-44bf-a623-2ed062878c58.jpg"}, {"id": "d71bc551-3fd9-43a9-9477-2acc8683a784", "name": "Nova Cleric", "set": "ONS", "set_name": "Onslaught", "released": "2002-10-07", "type_line": "Creature — Human Cleric", "rarity": "uncommon", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/b/2/b2048d84-b5e6-405c-9091-1997a0c4e1a5.jpg?1782719198", "img_normal": "https://cards.scryfall.io/normal/front/b/2/b2048d84-b5e6-405c-9091-1997a0c4e1a5.jpg?1782719198", "scryfall_uri": "https://scryfall.com/card/ons/45/nova-cleric?utm_source=api", "local": "img/cleric/d71bc551-3fd9-43a9-9477-2acc8683a784.jpg"}, {"id": "f4232466-dd6a-49bf-be6c-95905c3ded17", "name": "Ondu Cleric", "set": "ZEN", "set_name": "Zendikar", "released": "2009-10-02", "type_line": "Creature — Kor Cleric Ally", "rarity": "common", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/c/e/ced43447-fefc-482a-b8fa-33b9616aa532.jpg?1782715674", "img_normal": "https://cards.scryfall.io/normal/front/c/e/ced43447-fefc-482a-b8fa-33b9616aa532.jpg?1782715674", "scryfall_uri": "https://scryfall.com/card/zen/30/ondu-cleric?utm_source=api", "local": "img/cleric/f4232466-dd6a-49bf-be6c-95905c3ded17.jpg"}, {"id": "69bcdb42-c170-4848-b95b-f4621867d084", "name": "Arashin Cleric", "set": "FRF", "set_name": "Fate Reforged", "released": "2015-01-23", "type_line": "Creature — Human Cleric", "rarity": "common", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/1/0/10aeac19-6892-448e-9e5f-302051a089fc.jpg?