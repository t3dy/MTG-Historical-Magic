ror Commander", "released": "2024-09-27", "type_line": "Creature — Human Elf Cleric", "rarity": "uncommon", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/0/5/0555e095-8c6f-4436-80fe-99b641fad2df.jpg?1782689921", "img_normal": "https://cards.scryfall.io/normal/front/0/5/0555e095-8c6f-4436-80fe-99b641fad2df.jpg?1782689921", "scryfall_uri": "https://scryfall.com/card/dsc/69/moon-blessed-cleric?utm_source=api", "local": "img/cleric/89ed0598-a3ee-4d14-9a35-25e0dd80d9fb.jpg"}, {"id": "c40bc9f6-2b72-4ae1-b912-50075af59628", "name": "Remorseful Cleric", "set": "SOC", "set_name": "Secrets of Strixhaven Commander", "released": "2026-04-24", "type_line": "Creature — Spirit Cleric", "rarity": "rare", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/6/6/665a1bd1-db82-4db9-af7d-af161d31a696.jpg?1782683260", "img_normal": "https://cards.scryfall.io/normal/front/6/6/665a1bd1-db82-4db9-af7d-af161d31a696.jpg?1782683260", "scryfall_uri": "https://scryfall.com/card/soc/164/remorseful-cleric?utm_source=api", "local": "img/cleric/c40bc9f6-2b72-4ae1-b912-50075af59628.jpg"}], "flavor_snippets": [{"card": "Master Apothecary", "set": "ODY", "html": "It takes a remarkable <mark>cleric</mark> to turn a group of healers into a hospital.", "art": "https://cards.scryfall.io/art_crop/front/f/9/f9ff6624-ed0e-43d0-9519-112979b165f5.jpg?1782719445"}, {"card": "Leonin Abunas", "set": "2XM", "html": "Only leonin <mark>clerics</mark> who can survive the Razor Fields for one turning of the suns can stand in the Cave of Light.", "art": "https://cards.scryfall.io/art_crop/front/1/4/14397b59-ff0d-4838-92c3-9728bf6b0af5.jpg?1782744045"}, {"card": "Gangrenous Goliath", "set": "ONS", "html": "Cabal <mark>clerics</mark> don&#x27;t heal the sick—they heal the dead.", "art": "https://cards.scryfall.io/art_crop/front/6/9/69b58b6b-24cd-4440-b99c-d88d44b3c41c.jpg?1782719156"}, {"card": "Cosi's Ravager", "set": "DDI", "html": "&quot;Cosi has many followers. Even the volcano finds a way to do his bidding.&quot;\n—Zakken, Enclave <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/c/a/cab3f6db-862f-4d85-9879-6f1b74e67a6a.jpg?1782752366"}, {"card": "Fatal Mutation", "set": "SCG", "html": "&quot;You wear that shell as a mask. Now it&#x27;s your coffin.&quot;\n—Cabal <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/5/7/57cf9f50-8858-44a6-8bd5-0ce1e281a584.jpg?1782718986"}, {"card": "Breath of Life", "set": "VMA", "html": "&quot;Nothing can stop the power of life—not even death.&quot;\n—Onean <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/d/6/d6828916-c19e-4857-a6ba-047b81314d1f.jpg?1782751468"}, {"card": "Meeting of Minds", "set": "MOM", "html": "&quot;If something seems impossible, you probably haven&#x27;t tried asking for help.&quot;\n—Niambi, <mark>cleric</mark> of Dominaria", "art": "https://cards.scryfall.io/art_crop/front/5/0/508b8650-c283-4e54-abdc-32ec2fb1ee34.jpg?1782697780"}, {"card": "Wax-Wane Witness", "set": "BLB", "html": "Batfolk <mark>clerics</mark> consider the cycle of light and darkness as a sacred allegory of life and death.", "art": "https://cards.scryfall.io/art_crop/front/d/9/d90ea719-5320-46c6-a347-161853a14776.jpg?1782690607"}, {"card": "Lingering Death", "set": "SCG", "html": "&quot;Looks bad. I don&#x27;t know if he&#x27;ll make it through the night.&quot;\n—Cabal <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/f/1/f174fd76-f28d-4272-8cb0-7f66cd60579e.jpg?1782718986"}, {"card": "Cabal Surgeon", "set": "TOR", "html": "&quot;<mark>Clerics</mark> give up when their patients die. Can I help it if I&#x27;m more compassionate?&quot;", "art": "https://cards.scryfall.io/art_crop/front/2/9/29ce55a2-d838-48ab-862e-d419b0cda3c9.jpg?1782719308"}, {"card": "Landbind Ritual", "set": "ZEN", "html": "&quot;Honor this place, for our children&#x27;s children will stand here and speak these same words again.&quot;\n—Ayli, Kamsa <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/2/4/245357c6-b4cd-40f3-b7c2-413eee767239.jpg?1782715677"}, {"card": "Aura Extraction", "set": "ONS", "html": "Every day, Order <mark>clerics</mark> contain as much of the Mirari&#x27;s energy as possible, hoping to delay Otaria&#x27;s demise.", "art": "https://cards.scryfall.io/art_crop/front/5/5/55d16883-5e98-4dd2-92dd-0ba92f1099cb.jpg?1782719214"}, {"card": "Akroma's Blessing", "set": "VMA", "html": "The <mark>clerics</mark> saw her as a divine gift. She saw them only as allies in her war against Phage.", "art": "https://cards.scryfall.io/art_crop/front/b/e/be43fdd6-917e-4a49-a9b8-d1673b421dce.jpg?1782751470"}, {"card": "Hand of Emrakul", "set": "ROE", "html": "&quot;I believed in a beautiful god. But this is the true face of the divine.&quot;\n—Ayli, Kamsa <mark>cleric</mark>", "art": "https://cards.scryfall.io/art_crop/front/8/4/84d602f4-5876-416a-95e5-821a285358bf.jpg?1782715531"}], "mechanics_snippets": [{"card": "Westvale Abbey // Ormendahl, Profane Prince", "set": "INR", "html": "{T}: Add {C}.\n{5}, {T}, Pay 1 life: Create a 1/1 white and black Human <mark>Cleric</mark> creature token.\n{5}, {T}, Sacrifice five creatures: Transform this land, then untap it.\nFlying, lifelink, indestructible, haste"}, {"card": "Master Apothecary", "set": "ODY", "html": "Tap an untapped <mark>Cleric</mark> you control: Prevent the next 2 damage that would be dealt to any target this turn."}, {"card": "Acquisitions Expert", "set": "ZNR", "html": "When this creature enters, target opponent reveals a number of cards from their hand equal to the number of creatures in your party. You choose one of those cards. That player discards that card. (Your party consists of up to one each of <mark>Cleric</mark>, Rogue, Warrior, and Wizard.)"}, {"card": "Cascade Seer", "set": "ZNR", "html": "When this creature enters, scry X, where X is the number of creatures in your party. (Your party consists of up to one each of <mark>Cleric</mark>, Rogue, Warrior, and Wizard.)"}, {"card": "Whipgrass Entangler", "set": "LGN", "html": "{1}{W}: Until end of turn, target creature gains &quot;This creature can&#x27;t attack or block unless its controller pays {1} for each <mark>Cleric</mark> on the battlefield.&quot;"}, {"card": "Deadly Alliance", "set": "ZNR", "html": "This spell costs {1} less to cast for each creature in your party. (Your party consists of up to one each of <mark>Cleric</mark>, Rogue, Warrior, and Wizard.)\nDestroy target creature or planeswalker."}, {"card": "Gangrenous Goliath", "set": "ONS", "html": "Tap three untapped <mark>Clerics</mark> you control: Return this card from your graveyard to your hand."}, {"card": "Squad Commander", "set": "CLB", "html": "When this creature enters, create a 1/1 white Kor Warrior creature token for each creature in your party. (Your party consists of up to one each of <mark>Cleric</mark>, Rogue, Warrior, and Wizard.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/2/0/201f06ef-c180-4ce3-afaf-bec3b14c0222.jpg?1782701348", "small": "https://cards.scryfall.io/small/front/2/0/201f06ef-c180-4ce3-afaf-bec3b14c0222.jpg?1782701348", "card": "Dawnbringer Cleric"}}