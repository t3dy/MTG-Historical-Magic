cryfall_uri": "https://scryfall.com/card/mb2/576/glade-of-the-pump-spells?utm_source=api", "local": "img/spell/7bf6cb04-a987-4f8f-a070-7ba801ab01ac.jpg"}, {"id": "135135f2-1643-40db-91f2-bb7b956d212c", "name": "Spell Queller", "set": "INR", "set_name": "Innistrad Remastered", "released": "2025-01-24", "type_line": "Creature — Spirit", "rarity": "rare", "colors": ["U", "W"], "img_small": "https://cards.scryfall.io/small/front/a/9/a9364b43-ab2e-4433-91e8-88a0d5d5965c.jpg?1782726684", "img_normal": "https://cards.scryfall.io/normal/front/a/9/a9364b43-ab2e-4433-91e8-88a0d5d5965c.jpg?1782726684", "scryfall_uri": "https://scryfall.com/card/inr/248/spell-queller?utm_source=api", "local": "img/spell/135135f2-1643-40db-91f2-bb7b956d212c.jpg"}, {"id": "d64b0848-0193-4025-ba62-63ecd8fb9f50", "name": "Spell Pierce", "set": "DFT", "set_name": "Aetherdrift", "released": "2025-02-14", "type_line": "Instant", "rarity": "uncommon", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/8/d/8dd4374f-0301-4b2e-bc99-2cd19568cb3b.jpg?1782687910", "img_normal": "https://cards.scryfall.io/normal/front/8/d/8dd4374f-0301-4b2e-bc99-2cd19568cb3b.jpg?1782687910", "scryfall_uri": "https://scryfall.com/card/dft/64/spell-pierce?utm_source=api", "local": "img/spell/d64b0848-0193-4025-ba62-63ecd8fb9f50.jpg"}, {"id": "38877c68-b69b-4ee1-8e8f-5137a184a8f7", "name": "Spell Snare", "set": "ECL", "set_name": "Lorwyn Eclipsed", "released": "2026-01-23", "type_line": "Instant", "rarity": "uncommon", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/b/7/b7551b61-656e-4f37-b9da-73174db983b7.jpg?1782684089", "img_normal": "https://cards.scryfall.io/normal/front/b/7/b7551b61-656e-4f37-b9da-73174db983b7.jpg?1782684089", "scryfall_uri": "https://scryfall.com/card/ecl/71/spell-snare?utm_source=api", "local": "img/spell/38877c68-b69b-4ee1-8e8f-5137a184a8f7.jpg"}], "flavor_snippets": [{"card": "Sensory Deprivation", "set": "M14", "html": "They call it &quot;stitcher&#x27;s anesthesia,&quot; a <mark>spell</mark> to deaden the senses while the mad doctors begin their grisly work.", "art": "https://cards.scryfall.io/art_crop/front/7/0/7050735c-b232-47a6-a342-01795bfd0d46.jpg?1782713954"}, {"card": "Pongify", "set": "TDC", "html": "Some spellcrafting mistakes go on to become <mark>spells</mark> of their own.", "art": "https://cards.scryfall.io/art_crop/front/4/1/4131fa63-5afc-4b63-a4b4-f47b4bced87f.jpg?1782686815"}, {"card": "Nucklavee", "set": "DDS", "html": "It loathes all tastes but two: <mark>spells</mark> and flesh.", "art": "https://cards.scryfall.io/art_crop/front/f/d/fd706176-477a-49a9-bf47-0d10c0501227.jpg?1782749060"}, {"card": "Auriok Transfixer", "set": "MRD", "html": "&quot;My grandfather knew enough <mark>spells</mark> to fill a hundred scrolls. Nowadays, if a <mark>spell</mark> cannot fight the levelers, it is not even taught to our young.&quot;", "art": "https://cards.scryfall.io/art_crop/front/9/f/9f5c3f22-f228-4503-9d35-ee1b36a46ef0.jpg?1782718553"}, {"card": "Firefist Adept", "set": "DOM", "html": "The versatile &quot;fiery gauntlet&quot; is among the first <mark>spells</mark> young Ghitu mages learn.", "art": "https://cards.scryfall.io/art_crop/front/0/5/0569365d-9e50-436f-a8f3-90820ef06381.jpg?1782710121"}, {"card": "Yukora, the Prisoner", "set": "BOK", "html": "It took ninety-nine monks to weave the <mark>spell</mark> that trapped Yukora. Upon the death of the ninety-nine, the <mark>spell</mark> was broken, and the demon returned to the mortal world seeking vengeance for its imprisonment.", "art": "https://cards.scryfall.io/art_crop/front/5/4/54aeca31-1175-4d2d-adc3-e3682d7e9e07.jpg?1782718096"}, {"card": "Dredge the Mire", "set": "C20", "html": "Fortunately, the reanimation <mark>spell</mark> just missed the long-dead colony of dung scorpions.", "art": "https://cards.scryfall.io/art_crop/front/f/5/f57b4b40-bd46-4859-89f0-fa0bd04cc6e9.jpg?1782707394"}, {"card": "Polluted Bonds", "set": "SHM", "html": "The mystic bond between <mark>spellcasters</mark> and the land is just as vulnerable to attack as the casters themselves.", "art": "https://cards.scryfall.io/art_crop/front/c/6/c6439222-de30-44cd-a53f-a7de0cb00b8f.jpg?1782716164"}, {"card": "Burrenton Bombardier", "set": "DDF", "html": "The flasks provide ballast, a means of steering, and—with a little luck—a way to deliver ward-<mark>spells</mark> to cohorts below.", "art": "https://cards.scryfall.io/art_crop/front/f/d/fd872395-f351-4f7e-9290-c34d1c98a567.jpg?1782752984"}, {"card": "Duneblast", "set": "DMC", "html": "The Abzan turn to this <mark>spell</mark> only as a last resort, for its inevitable result is what they most dread: to be alone.", "art": "https://cards.scryfall.io/art_crop/front/4/a/4a38e37b-d458-402a-8b36-13a0e0a115ce.jpg?1782700612"}, {"card": "Tamanoa", "set": "CSP", "html": "When Freyalise spoke the World <mark>Spell</mark>, the tamanoa rose to bring a new morning to Terisiare.", "art": "https://cards.scryfall.io/art_crop/front/6/d/6d32955b-cbf6-429b-9513-17ca75d4ec2c.jpg?1782717011"}, {"card": "Ricochet Trap", "set": "WWK", "html": "In his last seconds, Remhas regretted using his most powerful <mark>spell</mark>.", "art": "https://cards.scryfall.io/art_crop/front/5/d/5d782375-9192-4ed0-bd79-f3404e5a1b01.jpg?1782715551"}, {"card": "Water Wings", "set": "WOE", "html": "Luckily for the plummeting Johann, the hydroloft <mark>spell</mark> was one he had actually mastered.", "art": "https://cards.scryfall.io/art_crop/front/4/e/4ea4993c-d1ba-4b33-955b-e0874fd2132f.jpg?1782696603"}, {"card": "Lose Focus", "set": "MH2", "html": "The <mark>spell</mark> wavered, caught on the tip of his tongue and at the edge of his awareness.", "art": "https://cards.scryfall.io/art_crop/front/9/8/985bdb0c-ce6c-4506-8163-76f3b2fdf5fb.jpg?1782704711"}], "mechanics_snippets": [{"card": "Nissa, Worldsoul Speaker", "set": "DRC", "html": "Landfall — Whenever a land you control enters, you get {E}{E} (two energy counters).\nYou may pay eight {E} rather than pay the mana cost for permanent <mark>spells</mark> you cast."}, {"card": "Mine Security", "set": "YEOE", "html": "Trample\nWhen this creature enters, conjure a card named Flametongue Kavu into the top eight cards of your library at random. It perpetually gains &quot;You may pay {0} rather than pay this <mark>spell</mark>&#x27;s mana cost.&quot;"}, {"card": "Phyrexian Broodstar", "set": "UNK", "html": "Affinity for Phyrexians (This <mark>spell</mark> costs {1} less to cast for each Phyrexian you control.)\nFlying\nPhyrexian Broodstar&#x27;s power and toughness are each equal to the number of Phyrexians you control."}, {"card": "Veil of Summer", "set": "M20", "html": "Draw a card if an opponent has cast a blue or black <mark>spell</mark> this turn. <mark>Spells</mark> you control can&#x27;t be countered this turn. You and permanents you control gain hexproof from blue and from black until end of turn. (You and they can&#x27;t be the targets of blue or black <mark>spells</mark> or abilities your opponents control.)"}, {"card": "Lattice Library", "set": "SOC", "html": "When this enchantment enters and whenever you cast your first <mark>spell</mark> with {X} in its mana cost each turn, create a 0/0 green and blue Fractal creature token. Put a number of +1/+1 counters on it equal to the number of study counters on this enchantment."}, {"card": "Strength of Night", "set": "APC", "html": "Kicker {B} (You may pay an additional {B} as you cast this <mark>spell</mark>.)\nCreatures you control get +1/+1 until end of turn. If this <mark>spell</mark> was kicked, Zombie creatures you control get an additional +2/+2 until end of turn."}, {"card": "Providence of Night", "set": "YECL", "html": "Protection from monocolored\nWhenever you cast a <mark>spell</mark> with hybrid mana in its mana cost, copy it. You may choose new targets for the copy."}, {"card": "Vault Guardsman", "set": "MSC", "html": "Convoke (Your creatures can help cast this <mark>spell</mark>. Each creature you tap while casting this <mark>spell</mark> pays for {1} or one mana of that creature&#x27;s color.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/a/4/a471b306-4941-4e46-a0cb-d92895c16f8a.jpg?1782687487", "small": "https://cards.scryfall.io/small/front/a/4/a471b306-4941-4e46-a0cb-d92895c16f8a.jpg?1782687487", "card": "Nissa, Worldsoul Speaker"}}