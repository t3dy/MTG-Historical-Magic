ron/152bbb62-195b-4de1-90c6-10dd953f8c4b.jpg"}, {"id": "b6864a26-9c13-4c6d-b0e0-d5b5ed9864e8", "name": "Skullmead Cauldron", "set": "DIS", "type_line": "Artifact", "rarity": "uncommon", "colors": [], "img_small": "https://cards.scryfall.io/small/front/1/d/1d8567c5-d068-42bb-a593-3849e65e29c0.jpg?1782717120", "img_normal": "https://cards.scryfall.io/normal/front/1/d/1d8567c5-d068-42bb-a593-3849e65e29c0.jpg?1782717120", "scryfall_uri": "https://scryfall.com/card/dis/167/skullmead-cauldron?utm_source=api", "local": "img/cauldron/b6864a26-9c13-4c6d-b0e0-d5b5ed9864e8.jpg"}, {"id": "a7dc2e62-1c50-4ed7-b71f-2d782a447a5e", "name": "Cauldron Familiar", "set": "JMP", "type_line": "Creature — Cat", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/3/2/32cf273e-b8f7-434b-9d5d-883dfd6f7423.jpg?1782706646", "img_normal": "https://cards.scryfall.io/normal/front/3/2/32cf273e-b8f7-434b-9d5d-883dfd6f7423.jpg?1782706646", "scryfall_uri": "https://scryfall.com/card/jmp/216/cauldron-familiar?utm_source=api", "local": "img/cauldron/a7dc2e62-1c50-4ed7-b71f-2d782a447a5e.jpg"}, {"id": "21153db6-552a-4956-a53a-a9dfb6968629", "name": "Feed the Cauldron", "set": "WOE", "type_line": "Instant", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/0/c/0cfd18a5-e06a-4cb5-b78e-de18ec641321.jpg?1782696592", "img_normal": "https://cards.scryfall.io/normal/front/0/c/0cfd18a5-e06a-4cb5-b78e-de18ec641321.jpg?1782696592", "scryfall_uri": "https://scryfall.com/card/woe/91/feed-the-cauldron?utm_source=api", "local": "img/cauldron/21153db6-552a-4956-a53a-a9dfb6968629.jpg"}, {"id": "dceb96a4-d3c5-43a2-93f6-50316e1e7a1b", "name": "Scalding Cauldron", "set": "ELD", "type_line": "Artifact", "rarity": "common", "colors": [], "img_small": "https://cards.scryfall.io/small/front/7/1/710d2782-2b23-441f-9890-6fa9c923b701.jpg?1782707781", "img_normal": "https://cards.scryfall.io/normal/front/7/1/710d2782-2b23-441f-9890-6fa9c923b701.jpg?1782707781", "scryfall_uri": "https://scryfall.com/card/eld/229/scalding-cauldron?utm_source=api", "local": "img/cauldron/dceb96a4-d3c5-43a2-93f6-50316e1e7a1b.jpg"}, {"id": "cb65ee08-bfdb-4c18-8967-8bcf31fcabfa", "name": "Witch's Cauldron", "set": "CMM", "type_line": "Artifact", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/5/1/51c15046-dd24-41aa-96f3-fb008a6988dd.jpg?1782733170", "img_normal": "https://cards.scryfall.io/normal/front/5/1/51c15046-dd24-41aa-96f3-fb008a6988dd.jpg?1782733170", "scryfall_uri": "https://scryfall.com/card/cmm/199/witchs-cauldron?utm_source=api", "local": "img/cauldron/cb65ee08-bfdb-4c18-8967-8bcf31fcabfa.jpg"}], "flavor_snippets": [{"card": "Feed the Cauldron", "set": "WOE", "html": "Kellan heard Agatha howl when he slammed into her, heard her scream as she fell into the <mark>cauldron</mark>, but couldn&#x27;t afford to think about the implications just yet.", "art": "https://cards.scryfall.io/art_crop/front/0/c/0cfd18a5-e06a-4cb5-b78e-de18ec641321.jpg?1782696592"}, {"card": "Blacklance Paragon", "set": "ELD", "html": "The Blacklances travel deep into the wilds, sometimes for years at a time, in search of the lost <mark>Cauldron</mark> of Eternity.", "art": "https://cards.scryfall.io/art_crop/front/f/e/fe0a63bb-dd94-429f-aa9b-21f3d1c53ae5.jpg?1782707882"}, {"card": "Forever Young", "set": "ELD", "html": "Those who say you only live once have never been touched by the <mark>Cauldron</mark> of Eternity.", "art": "https://cards.scryfall.io/art_crop/front/7/8/7873c1f9-572c-4740-82f8-cf3cbc7318d0.jpg?1782707874"}, {"card": "Festering Newt", "set": "JMP", "html": "Its back bubbles like a witch&#x27;s <mark>cauldron</mark>, and it smells just as vile.", "art": "https://cards.scryfall.io/art_crop/front/c/9/c9d7d31e-eaa7-4edf-8e98-5a191ec3b91d.jpg?1782706636"}, {"card": "Festive Funeral", "set": "ELD", "html": "&quot;Even as we mourn the last, we look to the next with joy. Hopefully, my new suitor will bring the <mark>Cauldron</mark> home.&quot;\n—Ayara, First of Locthwain", "art": "https://cards.scryfall.io/art_crop/front/9/0/90a90af0-eb40-40da-bf4b-f0af687c6430.jpg?1782707877"}, {"card": "Ragged Recluse // Odious Witch", "set": "VOW", "html": "&quot;Forgive my manners. It&#x27;s been so long since I had a guest for dinner.&quot;\nHer <mark>cauldron</mark> refilled, she settled in to wait for the next unsuspecting traveler to knock at her door.", "art": "https://cards.scryfall.io/art_crop/front/7/f/7fb728de-0d6e-4b32-b0c4-edd7382d1391.jpg?1782703100"}, {"card": "Penregon Strongbull", "set": "BRO", "html": "His child-lifting act was second only to his <mark>cauldron</mark>-punting routine.", "art": "https://cards.scryfall.io/art_crop/front/1/c/1c2deb43-7134-4f9c-b02d-78407a8986b1.jpg?1782699764"}, {"card": "Cauldron Familiar", "set": "JMP", "html": "Every day the cat returns to kill the same mouse, which sinks again into the <mark>cauldron</mark>&#x27;s brew.", "art": "https://cards.scryfall.io/art_crop/front/3/2/32cf273e-b8f7-434b-9d5d-883dfd6f7423.jpg?1782706646"}, {"card": "Locthwain Lancer", "set": "MOC", "html": "For years she believed persistence meant hunting for the <mark>Cauldron</mark> of Eternity. Now she knew it meant never giving up the fight against a world gone mad.", "art": "https://cards.scryfall.io/art_crop/front/7/4/7417067d-de28-404c-981e-e62b05d2bdf1.jpg?1782698121"}, {"card": "Scalding Cauldron", "set": "ELD", "html": "&quot;It&#x27;s a witch&#x27;s trick, this <mark>cauldron</mark> full of pain. I wouldn&#x27;t dump it on any but the wicked.&quot;", "art": "https://cards.scryfall.io/art_crop/front/7/1/710d2782-2b23-441f-9890-6fa9c923b701.jpg?1782707781"}], "mechanics_snippets": [{"card": "Banned Eldraine Card", "set": "UNK", "html": "As an additional cost to play Banned Eldraine Card, pay {B}, {3}{R}{G}, {3}{R}, {2}, {0}, or {1}{G}. It becomes a copy respectively of <mark>Cauldron</mark> Familiar, Escape to the Wilds, Fires of Invention, Lucky Clover, Mystic Sanctuary, Once Upon A Time for the rest of the game in all zones. (You can&#x27;t choose Oko. Because let&#x27;s be real, nobody wants to play against Oko again.)"}, {"card": "A-Cauldron Familiar", "set": "ELD", "html": "A-<mark>Cauldron</mark> Familiar can&#x27;t block.\nWhen <mark>Cauldron</mark> Familiar enters, each opponent loses 1 life and you gain 1 life.\nSacrifice a Food: Return <mark>Cauldron</mark> Familiar from your graveyard to the battlefield."}, {"card": "Bogbrew Witch", "set": "JMP", "html": "{2}, {T}: Search your library for a card named Festering Newt or Bubbling <mark>Cauldron</mark>, put it onto the battlefield tapped, then shuffle."}, {"card": "Agatha's Soul Cauldron", "set": "WOE", "html": "Creatures you control with +1/+1 counters on them have all activated abilities of all creature cards exiled with Agatha&#x27;s Soul <mark>Cauldron</mark>."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/5/d/5db19a94-1170-45a0-9f06-893bf58b7233.jpg?1782707880", "small": "https://cards.scryfall.io/small/front/5/d/5db19a94-1170-45a0-9f06-893bf58b7233.jpg?1782707880", "card": "Cauldron's Gift"}}