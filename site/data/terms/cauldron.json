{"slug": "cauldron", "root": "cauldron", "category": "item", "gloss": "the witch's brewing pot", "definition": null, "history": null, "def_sources": [], "is_keyword": false, "etymology": {"origin": "Old North French caudron ← Latin caldaria ‘hot bath’, from calidus ‘hot’", "first": "c. 1300", "note": "Just a big hot pot by origin — the witch’s cauldron is a domestic object made sinister by association.", "hook": "The kitchen pot that became a witch’s icon.", "lang": "Latin"}, "essay": null, "sources": ["Etymonline (Douglas Harper)", "Wiktionary", "classical lexica (Lewis & Short, LSJ, Bosworth–Toller)", "Ted's historical-magic DBs (WitchcraftStudiesDB, AgrippaDOP, MedievalMagicDB)"], "stats": {"flavor_total": 10, "oracle_total": 6, "in_flavor_cards": 10, "in_oracle_cards": 4, "name_match_count": 18, "by_variant": {"cauldron": 16}, "first_year": 2001, "colors": {"B": 17, "C": 8, "W": 1, "G": 3, "R": 3}, "by_year": {"2001": 1, "2006": 1, "2008": 1, "2011": 1, "2017": 1, "2018": 1, "2019": 6, "2020": 4, "2021": 2, "2022": 2, "2023": 6, "2026": 1}}, "cards": [{"id": "f398d222-f8e7-4983-9a77-267adef7f551", "name": "Agatha of the Vile Cauldron", "set": "WOE", "type_line": "Legendary Creature — Human Warlock", "rarity": "mythic", "colors": ["G", "R"], "img_small": "https://cards.scryfall.io/small/front/d/6/d6c48f07-63b7-4a60-8da6-ce77405abf1e.jpg?1782696516", "img_normal": "https://cards.scryfall.io/normal/front/d/6/d6c48f07-63b7-4a60-8da6-ce77405abf1e.jpg?1782696516", "scryfall_uri": "https://scryfall.com/card/woe/199/agatha-of-the-vile-cauldron?utm_source=api", "local": "img/cauldron/f398d222-f8e7-4983-9a77-267adef7f551.jpg"}, {"id": "c259e16f-2a44-4552-8678-815f757a02e8", "name": "Agatha's Soul Cauldron", "set": "WOE", "type_line": "Legendary Artifact", "rarity": "mythic", "colors": [], "img_small": "https://cards.scryfall.io/small/front/0/1/019b51b0-e5c6-4208-922b-7736686dddcd.jpg?1782696488", "img_normal": "https://cards.scryfall.io/normal/front/0/1/019b51b0-e5c6-4208