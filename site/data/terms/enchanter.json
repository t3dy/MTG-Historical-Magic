9ad9850908.jpg"}, {"id": "0355249a-8e4e-41db-9cea-1b901faffbe6", "name": "Witch Enchanter // Witch-Blessed Meadow", "set": "MH3", "set_name": "Modern Horizons 3", "released": "2024-06-14", "type_line": "Creature — Human Warlock // Land", "rarity": "uncommon", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/6/2/62061e7c-cf19-4f03-b8fa-2bdba62d6b0b.jpg?1782691173", "img_normal": "https://cards.scryfall.io/normal/front/6/2/62061e7c-cf19-4f03-b8fa-2bdba62d6b0b.jpg?1782691173", "scryfall_uri": "https://scryfall.com/card/mh3/239/witch-enchanter-witch-blessed-meadow?utm_source=api", "local": "img/enchanter/0355249a-8e4e-41db-9cea-1b901faffbe6.jpg"}, {"id": "1f0548f8-5dec-44b5-b5a9-e55fa4366e08", "name": "Enchanter's Bane", "set": "DSC", "set_name": "Duskmourn: House of Horror Commander", "released": "2024-09-27", "type_line": "Enchantment", "rarity": "rare", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/3/f/3f053af0-9a08-44e5-be57-6d0fabfde31a.jpg?1782689842", "img_normal": "https://cards.scryfall.io/normal/front/3/f/3f053af0-9a08-44e5-be57-6d0fabfde31a.jpg?1782689842", "scryfall_uri": "https://scryfall.com/card/dsc/164/enchanters-bane?utm_source=api", "local": "img/enchanter/1f0548f8-5dec-44b5-b5a9-e55fa4366e08.jpg"}, {"id": "8f4b8a19-72f4-48ed-ac05-62a7c7525797", "name": "Mesa Enchantress", "set": "DSC", "set_name": "Duskmourn: House of Horror Commander", "released": "2024-09-27", "type_line": "Creature — Human Druid", "rarity": "rare", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/c/4/c4f9e9fc-8b89-40ee-9b20-10e4a23e6333.jpg?1782689922", "img_normal": "https://cards.scryfall.io/normal/front/c/4/c4f9e9fc-8b89-40ee-9b20-10e4a23e6333.jpg?1782689922", "scryfall_uri": "https://scryfall.com/card/dsc/68/mesa-enchantress?utm_source=api", "local": "img/enchanter/8f4b8a19-72f4-48ed-ac05-62a7c7525797.jpg"}], "flavor_snippets": [{"card": "Krovikan Sorcerer", "set": "VMA", "html": "&quot;These sorcerers always seem to have another surprise up their sleeves.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/6/2/62909d11-9d2f-42a7-9b73-6b494bbe3f9e.jpg?1782751443"}, {"card": "Martyr of Frost", "set": "JVC", "html": "&quot;Do not call the Balduvians barbaric. Their magic is as potent as it is primal.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/0/e/0e7c25c9-1634-4675-b975-e9d477d1f8e1.jpg?1782750935"}, {"card": "Krovikan Elementalist", "set": "ICE", "html": "&quot;The Elementalists&#x27; talents could be useful if turned to other purposes.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/b/b/bbedca18-a074-4441-b0a9-7b14fdb07412.jpg?1782721703"}, {"card": "Rune Snag", "set": "UMA", "html": "&quot;Concentration is key. Without it, a mage conjures nothing but a splitting headache.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/4/0/40d72a34-0f31-4fec-b5a5-4574199bc312.jpg?1782747076"}, {"card": "Estrid's Invocation", "set": "MH3", "html": "<mark>Enchanters</mark> add layer upon layer of complexity to the world around them.", "art": "https://cards.scryfall.io/art_crop/front/8/9/8920e7e4-d89e-4ff9-8922-27fdc2f8ed6e.jpg?1782691136"}, {"card": "Femeref Enchantress", "set": "VIS", "html": "&quot;Then she spread a fine dust over the land, like a butterfly shaking its wing.&quot;\n—&quot;The <mark>Enchantress</mark>,&quot; Femeref tale", "art": "https://cards.scryfall.io/art_crop/front/2/0/20ba72c7-7957-4d02-b41e-c0132fe1f2e6.jpg?1782721284"}, {"card": "Zuran Spellcaster", "set": "ME2", "html": "&quot;A mage must be precise as well as potent; cautious, as well as clever.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/2/9/29d414a2-9afd-4bf1-908a-d9b5bea06222.jpg?1782753688"}, {"card": "Mesmeric Trance", "set": "ME2", "html": "&quot;Magic overused can freeze the mind. Creativity is more important than power.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/9/1/91129aeb-eed5-4b98-896f-fb3bab48b25d.jpg?1782753697"}, {"card": "Zuran Enchanter", "set": "ICE", "html": "&quot;We are Kjeldorans no more.&quot;\n—Zur the <mark>Enchanter</mark>", "art": "https://cards.scryfall.io/art_crop/front/7/2/721edcef-f40a-4d43-9d80-26161dc425cb.jpg?1782721716"}], "mechanics_snippets": [], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/6/2/62909d11-9d2f-42a7-9b73-6b494bbe3f9e.jpg?1782751443", "small": "https://cards.scryfall.io/small/front/6/2/62909d11-9d2f-42a7-9b73-6b494bbe3f9e.jpg?1782751443", "card": "Krovikan Sorcerer"}}