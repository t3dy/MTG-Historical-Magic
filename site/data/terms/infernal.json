", "type_line": "Instant", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/a/0/a09895d1-b41f-4dc6-aefa-774795d28e56.jpg?1782682216", "img_normal": "https://cards.scryfall.io/normal/front/a/0/a09895d1-b41f-4dc6-aefa-774795d28e56.jpg?1782682216", "scryfall_uri": "https://scryfall.com/card/msc/537/infernal-rebirth?utm_source=api", "local": "img/infernal/05a1e1ee-67f0-4158-a012-01612bc9cc70.jpg"}, {"id": "3fc640dd-6292-4d36-82fb-bd366bc00bd3", "name": "Infernal Scarring", "set": "M21", "type_line": "Enchantment — Aura", "rarity": "common", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/9/7/975e4b8e-add9-439c-9463-e2facee96c10.jpg?1782706949", "img_normal": "https://cards.scryfall.io/normal/front/9/7/975e4b8e-add9-439c-9463-e2facee96c10.jpg?1782706949", "scryfall_uri": "https://scryfall.com/card/m21/105/infernal-scarring?utm_source=api", "local": "img/infernal/3fc640dd-6292-4d36-82fb-bd366bc00bd3.jpg"}, {"id": "0ccc75a0-1bc2-461f-ab6f-0f182328a863", "name": "Inferno Fist", "set": "M15", "type_line": "Enchantment — Aura", "rarity": "common", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/7/2/721a42f4-5884-418f-b1f9-7cb651559ad0.jpg?1782713198", "img_normal": "https://cards.scryfall.io/normal/front/7/2/721a42f4-5884-418f-b1f9-7cb651559ad0.jpg?1782713198", "scryfall_uri": "https://scryfall.com/card/m15/150/inferno-fist?utm_source=api", "local": "img/infernal/0ccc75a0-1bc2-461f-ab6f-0f182328a863.jpg"}], "flavor_snippets": [{"card": "Rune-Scarred Demon", "set": "FDN", "html": "The litany of the <mark>infernal</mark> on his flesh pulses to the beating of his dark heart.", "art": "https://cards.scryfall.io/art_crop/front/1/e/1eae3165-554d-4759-8f18-794e2a7d8464.jpg?1782689107"}, {"card": "Screeching Phoenix", "set": "GS1", "html": "Its wings are a heavenly <mark>inferno</mark> that sets the world ablaze.", "art": "https://cards.scryfall.io/art_crop/front/4/b/4b9477ba-e198-4085-8733-fd392a5648e7.jpg?1782747657"}, {"card": "Curse of Bloodletting", "set": "DKA", "html": "It is the demon&#x27;s mark, an <mark>infernal</mark> claim on the flesh of the guilty.", "art": "https://cards.scryfall.io/art_crop/front/9/d/9dc4ac6f-0005-47f8-bee9-10429cc542e4.jpg?1782714599"}, {"card": "Los Diablos Missile Base", "set": "MSH", "html": "&quot;My men have been stationed here for weeks because of your <mark>infernal</mark> delays, Banner! Are you going to test that gamma bomb or not?&quot;\n—General &quot;Thunderbolt&quot; Ross", "art": "https://cards.scryfall.io/art_crop/front/2/1/2123fcb5-8181-47ab-9a2d-7ede5b5118e8.jpg?1782681682"}, {"card": "Pyromancer's Gauntlet", "set": "M14", "html": "An <mark>inferno</mark> is just a gesture away.", "art": "https://cards.scryfall.io/art_crop/front/9/b/9bde6763-2102-4adb-8048-fc9fe921205b.jpg?1782713886"}, {"card": "Fire Nation Cadets", "set": "TLA", "html": "Fire Nation training ensures that even the smallest flame burns into a raging <mark>inferno</mark>.", "art": "https://cards.scryfall.io/art_crop/front/1/a/1a3a862c-9c9a-41cd-94d1-2d0cff22a6cd.jpg?1782684570"}, {"card": "Cinderclasm", "set": "ZNR", "html": "Every <mark>inferno</mark> begins with a spark.", "art": "https://cards.scryfall.io/art_crop/front/5/5/5516cf97-805f-4a21-a4c6-2d6e55865336.jpg?1782706283"}, {"card": "Skull Catapult", "set": "ME2", "html": "&quot;Let any who doubt the evil of using the ancient devices look at this <mark>infernal</mark> machine. What manner of fiend would design such a sadistic device?&quot;\n—Sorine Relicbane, Soldevi heretic", "art": "https://cards.scryfall.io/art_crop/front/4/b/4bce5e36-99f3-415f-9064-ea83c96eb8ef.jpg?1782753616"}], "mechanics_snippets": [{"card": "Inferno Jet", "set": "HOU", "html": "<mark>Inferno</mark> Jet deals 6 damage to target opponent or planeswalker.\nCycling {2} ({2}, Discard this card: Draw a card.)"}, {"card": "Inferno", "set": "8ED", "html": "<mark>Inferno</mark> deals 6 damage to each creature and each player."}, {"card": "Inferno Trap", "set": "DDN", "html": "If you&#x27;ve been dealt damage by two or more creatures this turn, you may pay {R} rather than pay this spell&#x27;s mana cost.\n<mark>Inferno</mark> Trap deals 4 damage to target creature."}, {"card": "Infernal Harvest", "set": "VIS", "html": "As an additional cost to cast this spell, return X Swamps you control to their owner&#x27;s hand.\n<mark>Infernal</mark> Harvest deals X damage divided as you choose among any number of target creatures."}, {"card": "Inferno of the Star Mounts", "set": "AFR", "html": "This spell can&#x27;t be countered.\nFlying, haste\n{R}: <mark>Inferno</mark> of the Star Mounts gets +1/+0 until end of turn. When its power becomes 20 this way, it deals 20 damage to any target."}, {"card": "Unleash the Inferno", "set": "SNC", "html": "Unleash the <mark>Inferno</mark> deals 7 damage to target creature or planeswalker. When it deals excess damage this way, destroy target artifact or enchantment an opponent controls with mana value less than or equal to that amount of excess damage."}, {"card": "Jaya's Immolating Inferno", "set": "CMR", "html": "(You may cast a legendary sorcery only if you control a legendary creature or planeswalker.)\nJaya&#x27;s Immolating <mark>Inferno</mark> deals X damage to each of up to three targets."}, {"card": "Impossible Inferno", "set": "DSK", "html": "Impossible <mark>Inferno</mark> deals 6 damage to target creature.\nDelirium — If there are four or more card types among cards in your graveyard, exile the top card of your library. You may play it until the end of your next turn."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/a/0/a09895d1-b41f-4dc6-aefa-774795d28e56.jpg?1782682216", "small": "https://cards.scryfall.io/small/front/a/0/a09895d1-b41f-4dc6-aefa-774795d28e56.jpg?1782682216", "card": "Infernal Rebirth"}}