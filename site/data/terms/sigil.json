normal": "https://cards.scryfall.io/normal/front/8/6/861e8c51-0cda-497a-b289-a9f678f0e328.jpg?1782711844", "scryfall_uri": "https://scryfall.com/card/emn/153/crop-sigil?utm_source=api", "local": "img/sigil/76ee013d-5293-4432-b425-649a2e82bd74.jpg"}, {"id": "cb029c0f-b08a-4952-b236-8166b9f17119", "name": "Sigil of the New Dawn", "set": "UMA", "set_name": "Ultimate Masters", "released": "2018-12-07", "type_line": "Enchantment", "rarity": "uncommon", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/6/4/64393586-42c6-4874-9473-85c63c7ed2ad.jpg?1782747107", "img_normal": "https://cards.scryfall.io/normal/front/6/4/64393586-42c6-4874-9473-85c63c7ed2ad.jpg?1782747107", "scryfall_uri": "https://scryfall.com/card/uma/35/sigil-of-the-new-dawn?utm_source=api", "local": "img/sigil/cb029c0f-b08a-4952-b236-8166b9f17119.jpg"}, {"id": "b9d9d118-a073-4e73-90fe-026462d1d895", "name": "Grisly Sigil", "set": "SNC", "set_name": "Streets of New Capenna", "released": "2022-04-29", "type_line": "Sorcery", "rarity": "uncommon", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/6/3/6322e12d-b932-4ca1-a51d-e2a928140cc7.jpg?1782701615", "img_normal": "https://cards.scryfall.io/normal/front/6/3/6322e12d-b932-4ca1-a51d-e2a928140cc7.jpg?1782701615", "scryfall_uri": "https://scryfall.com/card/snc/82/grisly-sigil?utm_source=api", "local": "img/sigil/b9d9d118-a073-4e73-90fe-026462d1d895.jpg"}, {"id": "ae7e14cf-a275-4260-8d78-324429a042b7", "name": "Sigil of Myrkul", "set": "CLB", "set_name": "Commander Legends: Battle for Baldur's Gate", "released": "2022-06-10", "type_line": "Enchantment", "rarity": "uncommon", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/2/4/24fdf8bd-1893-4599-936a-fe0d6a87545f.jpg?1782701257", "img_normal": "https://cards.scryfall.io/normal/front/2/4/24fdf8bd-1893-4599-936a-fe0d6a87545f.jpg?1782701257", "scryfall_uri": "https://scryfall.com/card/clb/147/sigil-of-myrkul?utm_source=api", "local": "img/sigil/ae7e14cf-a275-4260-8d78-324429a042b7.jpg"}, {"id": "ffe0250d-112a-45c1-9c4c-617c8c7d243b", "name": "A-Sigil of Myrkul", "set": "HBG", "set_name": "Alchemy Horizons: Baldur's Gate", "released": "2022-08-11", "type_line": "Enchantment", "rarity": "uncommon", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/7/c/7cc1570e-f212-41cc-99cb-8366ccf2faea.jpg?1782737523", "img_normal": "https://cards.scryfall.io/normal/front/7/c/7cc1570e-f212-41cc-99cb-8366ccf2faea.jpg?1782737523", "scryfall_uri": "https://scryfall.com/card/hbg/A-168/a-sigil-of-myrkul?utm_source=api", "local": "img/sigil/ffe0250d-112a-45c1-9c4c-617c8c7d243b.jpg"}, {"id": "3b9b5b22-5a7d-4e37-a870-ca0f0efa4f36", "name": "Sigil of the Empty Throne", "set": "DSC", "set_name": "Duskmourn: House of Horror Commander", "released": "2024-09-27", "type_line": "Enchantment", "rarity": "rare", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/6/8/6875be24-1515-488f-a899-929c8e480dfd.jpg?1782689893", "img_normal": "https://cards.scryfall.io/normal/front/6/8/6875be24-1515-488f-a899-929c8e480dfd.jpg?1782689893", "scryfall_uri": "https://scryfall.com/card/dsc/103/sigil-of-the-empty-throne?utm_source=api", "local": "img/sigil/3b9b5b22-5a7d-4e37-a870-ca0f0efa4f36.jpg"}], "flavor_snippets": [{"card": "Deft Duelist", "set": "ALA", "html": "Some Serul Cove rogues traffic in stolen <mark>sigils</mark>, which fetch a high price from those who would rather pay for honor than earn it.", "art": "https://cards.scryfall.io/art_crop/front/c/4/c4885a83-9410-4c88-b45e-1e1626fe90ea.jpg?1782715929"}, {"card": "Akrasan Squire", "set": "ALA", "html": "Bant&#x27;s armies are primarily composed of members of the Mortar caste, loyal commoners who haven&#x27;t yet earned a <mark>sigil</mark>.", "art": "https://cards.scryfall.io/art_crop/front/5/9/59fdc045-b938-4321-aec3-51685cbbaa52.jpg?1782715999"}, {"card": "Simic Signet", "set": "DSC", "html": "For the Simic Combine, its <mark>sigil</mark> serves not as an emblem of honor but as a trademark. Its familiar image on any biological commodity attests to superb craftsmanship, ingenious innovation, and higher cost.", "art": "https://cards.scryfall.io/art_crop/front/b/f/bf222c78-f12e-4857-93da-fade99c740b8.jpg?1782689765"}, {"card": "Patron of the Valiant", "set": "CMR", "html": "&quot;Bant&#x27;s most gallant knights wear my <mark>sigil</mark>, and for that I am humbled.&quot;", "art": "https://cards.scryfall.io/art_crop/front/7/d/7db1e841-04e9-49ab-acbf-defd6d82140a.jpg?1782706071"}, {"card": "Rhox War Monk", "set": "MM3", "html": "Rhox monks are dedicated to spiritual growth and learning, and most bear the <mark>sigils</mark> of many students. However, they do not gladly suffer fools or those who disagree with their carefully wrought dogma.", "art": "https://cards.scryfall.io/art_crop/front/b/d/bd24e81d-d3a8-4550-bad9-b818f48cc700.jpg?1782749128"}, {"card": "Sigil Captain", "set": "CMD", "html": "&quot;One <mark>sigil</mark> awarded for valor, the other awarded for surviving Hellkite&#x27;s Pass.&quot;", "art": "https://cards.scryfall.io/art_crop/front/b/9/b9be8a9e-28d5-4acc-9f7d-a05cb3607bbb.jpg?1782714990"}, {"card": "Kiss of the Amesha", "set": "BBD", "html": "Once a year, Akrasa holds a joust that draws knights and their leotaus from every nation on Bant. The prize is an Akrasan <mark>sigil</mark>, but the true reward is the angel&#x27;s kiss.", "art": "https://cards.scryfall.io/art_crop/front/8/2/82843400-2705-4ec3-b677-1027df6db62e.jpg?1782709891"}, {"card": "Sigil Blessing", "set": "MM2", "html": "&quot;For unwavering commitment and unflinching strength, the Order of the White Orchid confers its <mark>sigil</mark>. Rise, knight-captain, and do your duty.&quot;", "art": "https://cards.scryfall.io/art_crop/front/7/2/72b5a580-c267-43f7-be77-fbc2928ff0ab.jpg?1782750541"}, {"card": "Call to Heel", "set": "BBD", "html": "On Bant, a <mark>sigil</mark> is both a prize of honor and a bond of duty. The one who bears it may be called to fulfill that charge at any moment.", "art": "https://cards.scryfall.io/art_crop/front/b/d/bdedbb84-7abe-420d-8429-c2d77ee0ae36.jpg?1782709968"}, {"card": "Valiant Guard", "set": "CON", "html": "As the outsiders invaded Bant, soldiers who once saw <mark>sigils</mark> as the highest marks of glory began to see the scars of battle as tokens of equal worth.", "art": "https://cards.scryfall.io/art_crop/front/8/3/83ec1486-900b-4763-9b5b-390cb00aff02.jpg?1782715889"}, {"card": "Topan Freeblade", "set": "GN2", "html": "&quot;My scars are my <mark>sigils</mark>. I will wear them with pride long after you&#x27;re gone.&quot;", "art": "https://cards.scryfall.io/art_crop/front/f/5/f5b27274-b3f0-4d94-9534-4e495ba53921.jpg?1782745002"}, {"card": "Sigiled Paladin", "set": "ALA", "html": "Each <mark>sigil</mark> marks the recognition of a great deed and signifies a duty owed to the one who granted it.", "art": "https://cards.scryfall.io/art_crop/front/4/b/4b22520d-c495-4528-9b24-4aa19e046a9e.jpg?1782715987"}, {"card": "Rafiq of the Many", "set": "CMM", "html": "Many <mark>sigils</mark>, one purpose.", "art": "https://cards.scryfall.io/art_crop/front/e/b/ebdd967d-b364-47ad-a1c2-49b155f72c5b.jpg?1782733064"}, {"card": "Sigil of the New Dawn", "set": "UMA", "html": "The <mark>sigil</mark> represents an honor that endures beyond death.", "art": "https://cards.scryfall.io/art_crop/front/6/4/64393586-42c6-4874-9473-85c63c7ed2ad.jpg?1782747107"}], "mechanics_snippets": [{"card": "Khârn the Betrayer", "set": "40K", "html": "<mark>Sigil</mark> of Corruption — When you lose control of Khârn the Betrayer, draw two cards."}, {"card": "Grisly Sigil", "set": "SNC", "html": "Choose target creature or planeswalker. If it was dealt noncombat damage this turn, Grisly <mark>Sigil</mark> deals 3 damage to it and you gain 3 life. Otherwise, Grisly <mark>Sigil</mark> deals 1 damage to it and you gain 1 life."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/c/4/c4885a83-9410-4c88-b45e-1e1626fe90ea.jpg?1782715929", "small": "https://cards.scryfall.io/small/front/c/4/c4885a83-9410-4c88-b45e-1e1626fe90ea.jpg?1782715929", "card": "Deft Duelist"}}