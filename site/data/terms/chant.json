arity": "common", "colors": ["G", "W"], "img_small": "https://cards.scryfall.io/small/front/9/a/9a17cbf6-3f38-4bc6-8448-881e19cffe06.jpg?1782708424", "img_normal": "https://cards.scryfall.io/normal/front/9/a/9a17cbf6-3f38-4bc6-8448-881e19cffe06.jpg?1782708424", "scryfall_uri": "https://scryfall.com/card/mh1/210/natures-chant?utm_source=api", "local": "img/chant/46e4ace2-e8bf-4b72-81de-286215886a10.jpg"}, {"id": "8d5a8513-0728-46ff-be72-3aefa07c7658", "name": "Silent-Chant Zubera", "set": "CHK", "type_line": "Creature — Zubera Spirit", "rarity": "common", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/2/7/272dfee6-9c90-4409-9289-f451261909e7.jpg?1782718247", "img_normal": "https://cards.scryfall.io/normal/front/2/7/272dfee6-9c90-4409-9289-f451261909e7.jpg?1782718247", "scryfall_uri": "https://scryfall.com/card/chk/45/silent-chant-zubera?utm_source=api", "local": "img/chant/8d5a8513-0728-46ff-be72-3aefa07c7658.jpg"}], "flavor_snippets": [{"card": "Cryptolith Rite", "set": "INR", "html": "The <mark>chant</mark> was incomprehensible, but its power was unmistakable.", "art": "https://cards.scryfall.io/art_crop/front/0/a/0a4e707f-b760-434d-ba97-a0fe651f3f6a.jpg?1782726735"}, {"card": "Gravecrawler", "set": "TDC", "html": "&quot;Jade-touched, wisteria-crowned, with gifts of gold and the Harvest&#x27;s blessing, return this honored one to us as sibsig.&quot;\n—Priests&#x27; <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/6/9/6987d609-ba0f-42bf-9b61-bdfb943c03b5.jpg?1782686870"}, {"card": "Needlebug", "set": "MRD", "html": "Near Tel-Jilad, the Tangle is almost silent, save for the trolls&#x27; <mark>chants</mark> and the skittering of needlebugs.", "art": "https://cards.scryfall.io/art_crop/front/d/5/d54fbd8a-1e2a-450e-98f2-26bbc9e9ac79.jpg?1782718454"}, {"card": "Soltari Crusader", "set": "TMP", "html": "&quot;Carry war to the Dauthi, no matter the way, no matter the world.&quot;\n—Soltari battle <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/6/c/6cd07471-b216-465c-9946-1eac689db32e.jpg?1782720994"}, {"card": "Painwracker Oni", "set": "CHK", "html": "&quot;Blood flows. Blood calls. Blood devours all and only blood remains.&quot;\n—Ogre <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/1/b/1b371b32-7758-4dc9-b4c5-1d1df1f1826a.jpg?1782718205"}, {"card": "Frazzle", "set": "GPT", "html": "The <mark>chant</mark> was interrupted, the components cooked, and Zok worried that it was his brain he smelled smoking.", "art": "https://cards.scryfall.io/art_crop/front/6/8/68b7f705-4d64-4551-8d76-826d91324e9e.jpg?1782717329"}, {"card": "Dosan's Oldest Chant", "set": "SOK", "html": "As Dosan&#x27;s <mark>chant</mark> grew in volume, a second, deeper voice rose up in harmony behind it, strong enough to shake the earth and yet vibrant enough to fill the spirit.", "art": "https://cards.scryfall.io/art_crop/front/b/5/b525f824-fcce-48cc-887d-98d4058b1d31.jpg?1782718002"}, {"card": "Ripclaw Wrangler", "set": "DFT", "html": "By the time Shantanu heard the Endriders <mark>chanting</mark> &quot;The claw!&quot; he was already in its grasp.", "art": "https://cards.scryfall.io/art_crop/front/d/4/d4981a4a-6eca-4f84-8715-8e2672507b59.jpg?1782687879"}, {"card": "Ekundu Cyclops", "set": "MIR", "html": "&quot;Big one I, One big eye. One-eye see Two-eye die!&quot;\n—Traditional cyclops <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/9/0/9047d292-8f5c-4a6b-b74e-c8dbf3e0ab24.jpg?1782721408"}, {"card": "Gutwrencher Oni", "set": "CHK", "html": "&quot;Blood drips. Blood sings. Blood devours all and only blood remains.&quot;\n—Ogre <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/7/6/7698a5da-5c70-4818-927b-3a923314e537.jpg?1782718215"}, {"card": "Gruul Cluestone", "set": "DGM", "html": "Forgotten under rocks and vines, Gruul symbols mark the sites of primitive rituals where shamans once <mark>chanted</mark> to the wild.", "art": "https://cards.scryfall.io/art_crop/front/b/c/bc47d1fe-8ab2-42f6-bcab-4bc2084ceba7.jpg?1782713987"}, {"card": "Goblin Digging Team", "set": "7ED", "html": "&quot;Dig. Dig. Dig. Dig. Dig. Dig. Die!&quot;\n—Goblin <mark>chant</mark>", "art": "https://cards.scryfall.io/art_crop/front/8/0/8000425a-4761-4370-95eb-6fe3df628482.jpg?1782719688"}, {"card": "Arcane Omens", "set": "SOS", "html": "Lluwen suddenly felt that he was seeing something very dangerous. The crackling magic, the thunderous <mark>chanting</mark>—the urge to turn and run replaced all his curiosity.", "art": "https://cards.scryfall.io/art_crop/front/d/3/d357d997-9d4e-4ade-81f2-37629853f13a.jpg?1782682977"}, {"card": "Merfolk Seastalkers", "set": "ZEN", "html": "&quot;Do they seek knowledge or wealth? Are they bandits or benefactors? It depends on who is <mark>chanting</mark> the tale.&quot;\n—Nikou, Joraga bard", "art": "https://cards.scryfall.io/art_crop/front/4/f/4fe5d069-45a0-46ea-b3ec-4e75f0531382.jpg?1782715665"}], "mechanics_snippets": [{"card": "Tallyman of Nurgle", "set": "40K", "html": "Lifelink\nThe Seven-fold <mark>Chant</mark> — At the beginning of your end step, if a creature died this turn, you draw a card and you lose 1 life. If seven or more creatures died this turn, instead you draw seven cards and you lose 7 life."}, {"card": "Legion's Chant", "set": "YLCI", "html": "Starting intensity 3\nReturn any number of creature cards with total mana value X or less from your graveyard to the battlefield, where X is Legion&#x27;s <mark>Chant</mark>&#x27;s intensity.\nAll Chorus cards you own intensify by 1."}, {"card": "Kamigawa Charm", "set": "UNK", "html": "Choose one —\n• Dosan&#x27;s Oldest <mark>Chant</mark> (Gain 6 life, draw a card.)\n• Kodama&#x27;s Reach (Search for two basic lands, put one onto the battlefield tapped and one to hand.)\n• Time of Need (Search for a legend.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/0/a/0a4e707f-b760-434d-ba97-a0fe651f3f6a.jpg?1782726735", "small": "https://cards.scryfall.io/small/front/0/a/0a4e707f-b760-434d-ba97-a0fe651f3f6a.jpg?1782726735", "card": "Cryptolith Rite"}}