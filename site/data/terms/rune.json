b60-4f1c-a71f-7ffbe94c8b13", "name": "Rune-Scarred Demon", "set": "FDN", "set_name": "Foundations", "released": "2024-11-15", "type_line": "Creature — Demon", "rarity": "rare", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/1/e/1eae3165-554d-4759-8f18-794e2a7d8464.jpg?1782689107", "img_normal": "https://cards.scryfall.io/normal/front/1/e/1eae3165-554d-4759-8f18-794e2a7d8464.jpg?1782689107", "scryfall_uri": "https://scryfall.com/card/fdn/184/rune-scarred-demon?utm_source=api", "local": "img/rune/14aefe99-fb60-4f1c-a71f-7ffbe94c8b13.jpg"}, {"id": "aea8345a-191d-4c62-8d15-a716a9934b66", "name": "Celes, Rune Knight", "set": "FIC", "set_name": "Final Fantasy Commander", "released": "2025-06-13", "type_line": "Legendary Creature — Human Wizard Knight", "rarity": "mythic", "colors": ["B", "R", "W"], "img_small": "https://cards.scryfall.io/small/front/3/0/30584c53-533b-4dc7-b07c-8600164a99b3.jpg?1782686055", "img_normal": "https://cards.scryfall.io/normal/front/3/0/30584c53-533b-4dc7-b07c-8600164a99b3.jpg?1782686055", "scryfall_uri": "https://scryfall.com/card/fic/1/celes-rune-knight?utm_source=api", "local": "img/rune/aea8345a-191d-4c62-8d15-a716a9934b66.jpg"}, {"id": "74d31e99-ab48-483a-a62e-5b424b27d017", "name": "Rune-Sealed Wall", "set": "FDN", "set_name": "Foundations", "released": "2026-04-24", "type_line": "Artifact Creature — Wall", "rarity": "uncommon", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/4/6/46674bd4-5160-44b2-bd2a-2da85c1e2697.jpg?1782683471", "img_normal": "https://cards.scryfall.io/normal/front/4/6/46674bd4-5160-44b2-bd2a-2da85c1e2697.jpg?1782683471", "scryfall_uri": "https://scryfall.com/card/fdn/745/rune-sealed-wall?utm_source=api", "local": "img/rune/74d31e99-ab48-483a-a62e-5b424b27d017.jpg"}], "flavor_snippets": [{"card": "Graven Lore", "set": "KHM", "html": "The <mark>runes</mark> glow beneath the snow, bearing memories of a time when the old gods ruled the realms.", "art": "https://cards.scryfall.io/art_crop/front/e/4/e4386e5c-32b1-4096-a93f-fedd1a4801fc.jpg?1782705514"}, {"card": "Runed Stalactite", "set": "MMA", "html": "When a changeling adopts a form no other changeling has taken, a <mark>rune</mark> appears in the caverns of Velis Vel to mark the event.", "art": "https://cards.scryfall.io/art_crop/front/a/5/a54f50fe-d4c0-49ba-9063-853c76ae3e19.jpg?1782751742"}, {"card": "Ayula's Influence", "set": "MH1", "html": "Ayula&#x27;s <mark>runic</mark> clawmarks ensure her territories are never left defenseless.", "art": "https://cards.scryfall.io/art_crop/front/1/b/1b9296ca-39a8-4aad-be92-0a56c704e950.jpg?1782708461"}, {"card": "Raven Wings", "set": "KHM", "html": "&quot;There are some places even our ships cannot travel. I would know their secrets too.&quot;\n—Inga <mark>Rune</mark>-Eyes", "art": "https://cards.scryfall.io/art_crop/front/6/0/60916ebe-6d84-4873-bd91-351bbe219c57.jpg?1782705407"}, {"card": "Skinbrand Goblin", "set": "2XM", "html": "&quot;These Gruul skin-<mark>runes</mark>—discern whether their patterns evoke streets, leylines, or both. You have four days.&quot;\n—Niv-Mizzet, to his assistant", "art": "https://cards.scryfall.io/art_crop/front/9/5/9535cdfe-d505-4ee5-bec0-cfd7aa4b2a23.jpg?1782743949"}, {"card": "Ascended Lawmage", "set": "CN2", "html": "A lawmage&#x27;s <mark>runic</mark> script is an act of governance given form: legislation written directly onto the air itself.", "art": "https://cards.scryfall.io/art_crop/front/e/9/e90d9cc4-9444-4610-ace5-c2981809b331.jpg?1782711676"}, {"card": "Hengegate Pathway // Mistgate Pathway", "set": "KHM", "html": "&quot;I cannot read these <mark>runes</mark>, yet somehow they seem like a warning. Have we passed unknowingly into a new realm?&quot;", "art": "https://cards.scryfall.io/art_crop/front/7/e/7ef37cb3-d803-47d7-8a01-9c803aa2eadc.jpg?1782705398"}, {"card": "Sigiled Skink", "set": "JOU", "html": "The <mark>runes</mark> seem to come alive as it moves, rippling like slow flames across its scales.", "art": "https://cards.scryfall.io/art_crop/front/3/7/37f84b4d-82db-4e3a-a099-2e438c0a6418.jpg?1782713383"}, {"card": "Nullmage Shepherd", "set": "KHC", "html": "The Skelle spent days carving <mark>runes</mark> and erecting their scorn poles. The herd crushed them to splinters in seconds.", "art": "https://cards.scryfall.io/art_crop/front/c/4/c4a15a09-cf68-411a-a18d-aaad00d308c9.jpg?1782705582"}, {"card": "Runed Servitor", "set": "JMP", "html": "Scholars had puzzled for centuries over the ruins at Tal Terig. Its secrets had always lived within one <mark>rune</mark>-carved head.", "art": "https://cards.scryfall.io/art_crop/front/e/f/efedf97b-8901-4558-8bd0-3f488097f686.jpg?1782706493"}, {"card": "Barkchannel Pathway // Tidechannel Pathway", "set": "KHM", "html": "&quot;Listen! The trees tell tales of their ancestors in the whisper-song of leaves.&quot;\n—Inga <mark>Rune</mark>-Eyes\n&quot;Trust in the path, and it will bear you to safety.&quot;\n—Inga <mark>Rune</mark>-Eyes", "art": "https://cards.scryfall.io/art_crop/front/b/6/b6de14ae-0132-4261-af00-630bf15918cd.jpg?1782705403"}, {"card": "Runebound Wolf", "set": "INR", "html": "The wolf&#x27;s captor hid his fear, but he knew someday the <mark>runes</mark> would fail, the collar would break, and the wolf would remember his face.", "art": "https://cards.scryfall.io/art_crop/front/8/e/8e220cc1-e13f-48da-b59b-91a556829ea5.jpg?1782726753"}, {"card": "Doubling Cube", "set": "10E", "html": "The cube&#x27;s surface is pockmarked with jagged <mark>runes</mark> that seem to shift when unobserved.", "art": "https://cards.scryfall.io/art_crop/front/3/d/3d946df5-f206-4241-bb55-97db67dc793c.jpg?1782716437"}, {"card": "Bearded Axe", "set": "KHM", "html": "Every dwarven artisan spends the first hundred years of their life forging a single weapon and infusing it with <mark>runic</mark> magic.", "art": "https://cards.scryfall.io/art_crop/front/2/3/2381dbab-e968-4bbc-b3a7-a1e55b066039.jpg?1782705317"}], "mechanics_snippets": [{"card": "Runeforge Champion", "set": "KHM", "html": "When this creature enters, you may search your library and/or graveyard for a <mark>Rune</mark> card, reveal it, and put it into your hand. If you search your library this way, shuffle."}, {"card": "Rune Snag", "set": "UMA", "html": "Counter target spell unless its controller pays {2} plus an additional {2} for each card named <mark>Rune</mark> Snag in each graveyard."}, {"card": "Rune-Tail, Kitsune Ascendant // Rune-Tail's Essence", "set": "SOK", "html": "When you have 30 or more life, flip <mark>Rune</mark>-Tail.\nPrevent all damage that would be dealt to creatures you control."}, {"card": "Inga Rune-Eyes", "set": "CMM", "html": "When Inga <mark>Rune</mark>-Eyes enters, scry 3.\nWhen Inga <mark>Rune</mark>-Eyes dies, draw three cards if three or more creatures died this turn."}, {"card": "Runed Crown", "set": "KHM", "html": "When this Equipment enters, you may search your library, hand, and/or graveyard for a <mark>Rune</mark> card and put it onto the battlefield attached to this Equipment. If you search your library this way, shuffle."}, {"card": "Burning-Rune Demon", "set": "KHM", "html": "When this creature enters, you may search your library for exactly two cards not named Burning-<mark>Rune</mark> Demon that have different names. If you do, reveal those cards. An opponent chooses one of them. Put the chosen card into your hand and the other into your graveyard, then shuffle."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/0/e/0e31b716-f325-445a-9098-9ca75d7b35a4.jpg?1782705536", "small": "https://cards.scryfall.io/small/front/0/e/0e31b716-f325-445a-9098-9ca75d7b35a4.jpg?1782705536", "card": "Rune of Sustenance"}}