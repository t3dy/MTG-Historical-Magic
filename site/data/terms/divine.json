lience", "set": "FDN", "set_name": "Foundations", "released": "2024-11-15", "type_line": "Instant", "rarity": "uncommon", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/f/3/f3a08245-a535-4d24-b8c0-78759bb9c4b0.jpg?1782689256", "img_normal": "https://cards.scryfall.io/normal/front/f/3/f3a08245-a535-4d24-b8c0-78759bb9c4b0.jpg?1782689256", "scryfall_uri": "https://scryfall.com/card/fdn/10/divine-resilience?utm_source=api", "local": "img/divine/4f6e2e47-34df-4bf3-a546-e06b42840167.jpg"}, {"id": "97f33045-8b89-47fb-ba28-fa06f42c4b5e", "name": "Deceptive Divination", "set": "PSSC", "set_name": "Secret Lair Showcase Planes", "released": "2025-02-21", "type_line": "Plane — Secret Lair", "rarity": "common", "colors": [], "img_small": "https://cards.scryfall.io/small/front/6/d/6d241115-60b8-4fab-9877-4e2d35d638b9.jpg?1782726142", "img_normal": "https://cards.scryfall.io/normal/front/6/d/6d241115-60b8-4fab-9877-4e2d35d638b9.jpg?1782726142", "scryfall_uri": "https://scryfall.com/card/pssc/1/deceptive-divination?utm_source=api", "local": "img/divine/97f33045-8b89-47fb-ba28-fa06f42c4b5e.jpg"}, {"id": "fce450a6-1a17-4315-9b2a-d9e7abf65aa6", "name": "Cunning Azurescale // Divining Dive", "set": "YTDM", "set_name": "Alchemy: Tarkir", "released": "2025-04-29", "type_line": "Creature — Dragon // Instant — Omen", "rarity": "rare", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/7/0/705bd7ae-5664-4a45-b2a7-8451ea2b1391.jpg?1782725680", "img_normal": "https://cards.scryfall.io/normal/front/7/0/705bd7ae-5664-4a45-b2a7-8451ea2b1391.jpg?1782725680", "scryfall_uri": "https://scryfall.com/card/ytdm/4/cunning-azurescale-divining-dive?utm_source=api", "local": "img/divine/fce450a6-1a17-4315-9b2a-d9e7abf65aa6.jpg"}, {"id": "14b839ef-80b1-4e7d-b2fd-38e973899cde", "name": "Ragnarok, Divine Deliverance", "set": "FIN", "set_name": "Final Fantasy", "released": "2025-06-13", "type_line": "Legendary Creature — Beast Avatar", "rarity": "uncommon", "colors": ["B", "G"], "img_small": "https://cards.scryfall.io/small/front/0/1/01c5bafe-c995-4cef-90fb-7ccb95858511.jpg?1782686523", "img_normal": "https://cards.scryfall.io/normal/front/0/1/01c5bafe-c995-4cef-90fb-7ccb95858511.jpg?1782686523", "scryfall_uri": "https://scryfall.com/card/fin/99b/ragnarok-divine-deliverance?utm_source=api", "local": "img/divine/14b839ef-80b1-4e7d-b2fd-38e973899cde.jpg"}, {"id": "5917216f-5b42-41fa-8976-401bdbeb782e", "name": "Divine Visitation", "set": "MSC", "set_name": "Marvel Super Heroes Commander", "released": "2026-06-26", "type_line": "Enchantment", "rarity": "mythic", "colors": ["W"], "img_small": "https://cards.scryfall.io/small/front/d/a/dabd95db-b4ca-446b-bb68-6f52cec9ed2a.jpg?1782682556", "img_normal": "https://cards.scryfall.io/normal/front/d/a/dabd95db-b4ca-446b-bb68-6f52cec9ed2a.jpg?1782682556", "scryfall_uri": "https://scryfall.com/card/msc/131/divine-visitation?utm_source=api", "local": "img/divine/5917216f-5b42-41fa-8976-401bdbeb782e.jpg"}], "flavor_snippets": [{"card": "Contagious Nim", "set": "SOM", "html": "&quot;This species has grown to be my preferred receptacle for our <mark>divine</mark> message.&quot;\n—Sheoldred, Whispering One", "art": "https://cards.scryfall.io/art_crop/front/e/8/e83a9dea-2aa1-48cd-afe2-f98057b95f6e.jpg?1782715332"}, {"card": "Courier of Comestibles", "set": "TMT", "html": "Forgiveness is <mark>divine</mark>, but never pay full price for late pizza.", "art": "https://cards.scryfall.io/art_crop/front/5/3/53f5f704-2265-42bb-bff5-fd9d85bc2bfb.jpg?1782683657"}, {"card": "Dawnglare Invoker", "set": "CM2", "html": "&quot;What we knew as Emeria, Ula, and Cosi were not <mark>divine</mark> beings at all, but a cruel trick, and a grave error.&quot;\n—*The Invokers&#x27; Tales*", "art": "https://cards.scryfall.io/art_crop/front/c/7/c7cc4332-8d8a-47f5-9583-219be4f2030a.jpg?1782709848"}, {"card": "Serra Disciple", "set": "DOM", "html": "Theologians now believe the Ancestor was another <mark>divine</mark> form of Serra.", "art": "https://cards.scryfall.io/art_crop/front/8/3/8359c3a8-d826-4326-a899-9f60ca774308.jpg?1782710173"}, {"card": "Sky Diamond", "set": "CLB", "html": "Every facet a window into Oghma&#x27;s <mark>divine</mark> insight.", "art": "https://cards.scryfall.io/art_crop/front/d/4/d47abfb2-9bcf-485c-9bd4-2c09b714eb32.jpg?1782701139"}, {"card": "Divine Transformation", "set": "ME1", "html": "Glory surged through her and radiance surrounded her. All things were possible with the blessing of the <mark>Divine</mark>.", "art": "https://cards.scryfall.io/art_crop/front/7/b/7b733fb5-3ece-452c-a360-330fd202bb0f.jpg?1782753888"}, {"card": "Soothsayer Adept", "set": "STX", "html": "One of the first lessons <mark>divination</mark> students learn is how to recognize the difference between a portent and a simple surface ripple.", "art": "https://cards.scryfall.io/art_crop/front/e/b/eb93c9d2-88eb-403d-bb67-8e8b0462ac27.jpg?1782704980"}, {"card": "Sacred Boon", "set": "ME2", "html": "&quot;<mark>Divine</mark> gifts are granted to those who are worthy.&quot;\n—Halvor Arenson, Kjeldoran priest", "art": "https://cards.scryfall.io/art_crop/front/f/8/f8086253-5a66-4161-bdef-f460851368ed.jpg?1782753708"}, {"card": "Serra Redeemer", "set": "BLB", "html": "&quot;Heroism is neither a strong arm nor a <mark>divine</mark> destiny. It is the choice to stand unbowed against impossible odds.&quot;", "art": "https://cards.scryfall.io/art_crop/front/2/3/230b9aef-bd9c-4332-ace4-b5b065bac6d8.jpg?1782690313"}, {"card": "Devastation Tide", "set": "C18", "html": "It&#x27;s hard to argue with a force made of <mark>divine</mark> will.", "art": "https://cards.scryfall.io/art_crop/front/2/d/2d493bd6-af71-45be-bd4c-1d8f94bca19e.jpg?1782709356"}, {"card": "Reprobation", "set": "MH1", "html": "There was a time all craven beasts cowered before Avacyn&#x27;s <mark>divine</mark> might.", "art": "https://cards.scryfall.io/art_crop/front/b/1/b1349c3d-39ad-40ba-897e-59e5b76de853.jpg?1782708552"}, {"card": "Favor of the Overbeing", "set": "EVE", "html": "Enlightenment is the mundane seen from the vantage point of the <mark>divine</mark>.", "art": "https://cards.scryfall.io/art_crop/front/9/b/9bf061f8-3aec-429a-bde7-7c110f872416.jpg?1782716011"}, {"card": "Eligeth, Crossroads Augur", "set": "CMR", "html": "&quot;There&#x27;s no better place to <mark>divine</mark> the future than at a nexus of branching presents.&quot;", "art": "https://cards.scryfall.io/art_crop/front/1/a/1a0adf34-1a2b-497b-aaab-4b2b998ed8b3.jpg?1782706055"}, {"card": "Stronghold Taskmaster", "set": "STH", "html": "&quot;With the completion of each joyous task, we are closer to Yawgmoth&#x27;s <mark>divine</mark> vision.&quot;\n—Stronghold architect, journal", "art": "https://cards.scryfall.io/art_crop/front/6/1/6171c210-01b5-45a9-9dd3-dbf96a33a750.jpg?1782720847"}], "mechanics_snippets": [{"card": "Vanille, Cheerful l'Cie", "set": "FIN", "html": "At the beginning of your first main phase, if you both own and control Vanille and a creature named Fang, Fearless l&#x27;Cie, you may pay {3}{B}{G}. If you do, exile them, then meld them into Ragnarok, <mark>Divine</mark> Deliverance."}, {"card": "Divine Arrow", "set": "JMP", "html": "<mark>Divine</mark> Arrow deals 4 damage to target attacking or blocking creature."}, {"card": "Jitte and Divining Top", "set": "UNK", "html": "Whenever equipped creature deals combat damage, put 2 charge counters on Jitte and <mark>Divining</mark> Top."}, {"card": "Moon-Blessed Cleric", "set": "DSC", "html": "<mark>Divine</mark> Intervention — When this creature enters, you may search your library for an enchantment card, reveal it, then shuffle and put that card on top."}, {"card": "Divine Retribution", "set": "MIR", "html": "<mark>Divine</mark> Retribution deals damage to target attacking creature equal to the number of attacking creatures."}, {"card": "Toofer, Keeper of the Full Grip", "set": "MB2", "html": "Whenever a spell you control causes you to gain card advantage, each opponent loses 2 life. (You gain card advantage each time a spell you control resolves and you end up having more cards relative to your opponents than before that spell resolved. <mark>Divination</mark>, Annihilate, and Wrath of God can all be card advantage. And remember: tokens aren&#x27;t cards!)"}, {"card": "Divine Deflection", "set": "AVR", "html": "Prevent the next X damage that would be dealt to you and/or permanents you control this turn. If damage is prevented this way, <mark>Divine</mark> Deflection deals that much damage to any target."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/1/2/1200f68a-a8ea-4777-b6b0-de48b2203fd1.jpg?1782707633", "small": "https://cards.scryfall.io/small/front/1/2/1200f68a-a8ea-4777-b6b0-de48b2203fd1.jpg?1782707633", "card": "Deny the Divine"}}