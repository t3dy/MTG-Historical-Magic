", "rarity": "rare", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/a/9/a95b6baf-01e6-49c3-9a26-394b127d53c3.jpg?1782682991", "img_normal": "https://cards.scryfall.io/normal/front/a/9/a95b6baf-01e6-49c3-9a26-394b127d53c3.jpg?1782682991", "scryfall_uri": "https://scryfall.com/card/sos/55/jadzi-steward-of-fate-oracles-gift?utm_source=api", "local": "img/oracle/c63b3511-d597-4c6e-9094-eabdeaa8a394.jpg"}, {"id": "00e75a6b-699e-4824-86e5-66d45245cd9b", "name": "Oracle's Restoration", "set": "SOS", "set_name": "Secrets of Strixhaven", "released": "2026-04-24", "type_line": "Sorcery", "rarity": "common", "colors": ["G"], "img_small": "https://cards.scryfall.io/small/front/0/8/0863a19d-4511-4a78-98dd-d194afd1c39b.jpg?1782682903", "img_normal": "https://cards.scryfall.io/normal/front/0/8/0863a19d-4511-4a78-98dd-d194afd1c39b.jpg?1782682903", "scryfall_uri": "https://scryfall.com/card/sos/156/oracles-restoration?utm_source=api", "local": "img/oracle/00e75a6b-699e-4824-86e5-66d45245cd9b.jpg"}], "flavor_snippets": [{"card": "Ranger en-Vec", "set": "TMP", "html": "&quot;The path of least resistance will seldom lead you beyond your doorstep.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/4/a/4a89e82c-7206-4d74-95c6-ad3627e5a9ce.jpg?1782720907"}, {"card": "Wasteland", "set": "EMA", "html": "&quot;The land promises nothing and keeps its promise.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/a/a/aaafb9bc-7cea-4624-a227-595544fa42b0.jpg?1782749799"}, {"card": "Boulderfall", "set": "THS", "html": "&quot;Defeating the Meletians was not so difficult. I needed only to move a mountain.&quot;\n—Eocles, <mark>oracle</mark> of Purphoros", "art": "https://cards.scryfall.io/art_crop/front/6/6/66470bac-cce0-4e79-82f9-9fb77aa950eb.jpg?1782713783"}, {"card": "Rageblood Shaman", "set": "JMP", "html": "&quot;I see a spark of pure rage. Soon that spark will spread from the depths of Kragma. Soon its fire will engulf the polis.&quot;\n—Hira, street <mark>oracle</mark>", "art": "https://cards.scryfall.io/art_crop/front/5/6/568a31c0-799b-48b6-a91c-95d176b22670.jpg?1782706564"}, {"card": "Archetype of Aggression", "set": "BNG", "html": "&quot;Did Purphoros bless Maikal because of his rage? Or did Maikal&#x27;s rage blossom after he&#x27;d been blessed? Only the gods know.&quot;\n—Eocles, <mark>oracle</mark> of Purphoros", "art": "https://cards.scryfall.io/art_crop/front/1/3/13946413-c76d-41a8-a699-404fd56b2067.jpg?1782713506"}, {"card": "Magma Jet", "set": "JMP", "html": "Some Akroans make the dangerous pilgrimage to the volcanic temples of Purphoros, where <mark>oracles</mark> known as flamespeakers glean omens from lava.", "art": "https://cards.scryfall.io/art_crop/front/2/9/2975ce11-589a-4da8-a016-854bbaeb869c.jpg?1782706570"}, {"card": "Fanatical Devotion", "set": "NEM", "html": "The <mark>Oracle</mark> told Eladamri he would save his people by abandoning them. His followers adopted that ideal.", "art": "https://cards.scryfall.io/art_crop/front/b/e/be0ed1fb-d380-4e3e-a43f-c39660a996e9.jpg?1782720222"}, {"card": "Krakilin", "set": "TPR", "html": "&quot;A perfect reflection of its world: brutal, fetal, and lacking truth.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/6/d/6d19ce30-a33e-4d34-a73e-21ff79b010e5.jpg?1782750683"}, {"card": "Zealots en-Dal", "set": "EXO", "html": "&quot;Great chains shall free our warriors.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/6/a/6a9fb486-1d6a-478e-af6e-fd8539dc646d.jpg?1782720806"}, {"card": "Brine Giant", "set": "THB", "html": "The <mark>oracles</mark> of Meletis foresaw neither its rise from the depths nor the destruction it would leave in its wake.", "art": "https://cards.scryfall.io/art_crop/front/6/8/6811a9dc-e521-4c9e-accb-1efb8346c1db.jpg?1782707634"}, {"card": "Ruination", "set": "CMD", "html": "&quot;We have built a wall upon sand. The wall will vanish. The sand will remain.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/6/3/6330d925-96a8-47e1-855d-035ddc2af709.jpg?1782715043"}, {"card": "Opportunist", "set": "TMP", "html": "The third time the <mark>Oracle</mark> glanced suspiciously at him, Starke decided she had glanced twice too often.", "art": "https://cards.scryfall.io/art_crop/front/a/e/ae0026c0-8f61-4485-8909-6a44c2ca9169.jpg?1782720932"}, {"card": "Predator, Flagship", "set": "CMA", "html": "&quot;The scourge of Skyshroud is airborne once more.&quot;\n—<mark>Oracle</mark> *en*-Vec", "art": "https://cards.scryfall.io/art_crop/front/4/9/4910ee8b-ec00-4a5e-859e-b865b23117da.jpg?1782710871"}, {"card": "Thought Reflection", "set": "2XM", "html": "Only when two <mark>oracles</mark> speak in unison is an omen accepted as truth.", "art": "https://cards.scryfall.io/art_crop/front/e/1/e169e197-5ef4-454d-a31f-fcadedb74cfc.jpg?1782744004"}], "mechanics_snippets": [{"card": "M'Odo, the Gnarled Oracle", "set": "PH17", "html": "Eminence — {X}, Discard a card: Target player reveals cards from the top of their library until they reveal a creature card with converted mana cost X or less. Put that card onto the battlefield under your control, then that player shuffles the rest into their library. Activate this ability only if M&#x27;Odo, the Gnarled <mark>Oracle</mark> is on the battlefield or in the command zone."}, {"card": "Oracle of the Alpha", "set": "MB2", "html": "Flying\nWhen <mark>Oracle</mark> of the Alpha enters the battlefield, conjure the Power Nine into your library, then shuffle.\nWhenever <mark>Oracle</mark> of the Alpha attacks, scry 1."}, {"card": "Jadzi, Oracle of Arcavios // Journey to the Oracle", "set": "STX", "html": "You may put any number of land cards from your hand onto the battlefield. Then if you control eight or more lands, you may discard a card. If you do, return Journey to the <mark>Oracle</mark> to its owner&#x27;s hand."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/0/8/0863a19d-4511-4a78-98dd-d194afd1c39b.jpg?1782682903", "small": "https://cards.scryfall.io/small/front/0/8/0863a19d-4511-4a78-98dd-d194afd1c39b.jpg?1782682903", "card": "Oracle's Restoration"}}