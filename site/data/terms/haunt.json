//cards.scryfall.io/normal/front/4/7/478d236c-9778-435a-ac21-bd0017a17d5b.jpg?1782687797", "scryfall_uri": "https://scryfall.com/card/dft/207/haunt-the-network?utm_source=api", "local": "img/haunt/7e074b14-0ec8-439b-9b83-5f7c1a904384.jpg"}, {"id": "47944bf1-b954-4143-b479-45c10071e35a", "name": "Haunted Hellride", "set": "DFT", "set_name": "Aetherdrift", "released": "2025-02-14", "type_line": "Artifact — Vehicle", "rarity": "uncommon", "colors": ["B", "U"], "img_small": "https://cards.scryfall.io/small/front/e/2/e2ce0d37-d5d7-49dd-885e-9998bb8abede.jpg?1782687797", "img_normal": "https://cards.scryfall.io/normal/front/e/2/e2ce0d37-d5d7-49dd-885e-9998bb8abede.jpg?1782687797", "scryfall_uri": "https://scryfall.com/card/dft/208/haunted-hellride?utm_source=api", "local": "img/haunt/47944bf1-b954-4143-b479-45c10071e35a.jpg"}, {"id": "334c284e-7bc3-4c18-9f8d-4d846f80008e", "name": "Haunting Voyage", "set": "ECC", "set_name": "Lorwyn Eclipsed Commander", "released": "2026-01-23", "type_line": "Sorcery", "rarity": "mythic", "colors": ["B"], "img_small": "https://cards.scryfall.io/small/front/2/0/203ddc5e-3824-4a97-b97d-aeda7b82c704.jpg?1782684239", "img_normal": "https://cards.scryfall.io/normal/front/2/0/203ddc5e-3824-4a97-b97d-aeda7b82c704.jpg?1782684239", "scryfall_uri": "https://scryfall.com/card/ecc/75/haunting-voyage?utm_source=api", "local": "img/haunt/334c284e-7bc3-4c18-9f8d-4d846f80008e.jpg"}, {"id": "b0b58a03-462c-4964-97c7-42bc777ec23e", "name": "Haunted Mire", "set": "SOC", "set_name": "Secrets of Strixhaven Commander", "released": "2026-04-24", "type_line": "Land — Swamp Forest", "rarity": "common", "colors": ["B", "G"], "img_small": "https://cards.scryfall.io/small/front/3/e/3e041aef-5771-4a3f-af07-e85a66c48979.jpg?1782683093", "img_normal": "https://cards.scryfall.io/normal/front/3/e/3e041aef-5771-4a3f-af07-e85a66c48979.jpg?1782683093", "scryfall_uri": "https://scryfall.com/card/soc/379/haunted-mire?utm_source=api", "local": "img/haunt/b0b58a03-462c-4964-97c7-42bc777ec23e.jpg"}], "flavor_snippets": [{"card": "Shizo, Death's Storehouse", "set": "DMC", "html": "Centuries ago, Shizo was a verdant field of wildflowers. After 891 samurai died in a single battle on its grasses, it became a <mark>haunted</mark> moor.", "art": "https://cards.scryfall.io/art_crop/front/0/9/099352e2-38c8-4fb4-a25f-6d928aa20f9e.jpg?1782700563"}, {"card": "Natural End", "set": "M20", "html": "The <mark>haunted</mark> blade shattered, and the geist drifted gratefully to the Blessed Sleep.", "art": "https://cards.scryfall.io/art_crop/front/8/4/84dcd314-f4d2-461e-a66e-7b1d8f141879.jpg?1782708267"}, {"card": "Tree of Perdition", "set": "ECC", "html": "A <mark>haunted</mark> husk of bark, its cursed whispers linger on the wind.", "art": "https://cards.scryfall.io/art_crop/front/7/5/750b4c88-26c7-43ec-b6b9-ece3263dfd59.jpg?1782684257"}, {"card": "Cloak of Mists", "set": "GS1", "html": "Mystery lies beneath the <mark>haunting</mark> mists. Never stay where obscurity deepens.", "art": "https://cards.scryfall.io/art_crop/front/b/3/b36f41fa-b676-475e-bc2a-7dce5f249989.jpg?1782747668"}, {"card": "Ruin Ghost", "set": "WWK", "html": "The Forsaken Ones <mark>haunt</mark> the ruins that flicker in and out of the spirit realm. Such sites are hard to find and even harder to loot.", "art": "https://cards.scryfall.io/art_crop/front/f/0/f0b60f10-0997-46ec-8914-f5cdde76cf75.jpg?1782715576"}, {"card": "Karn", "set": "PVAN", "html": "Both part of the Legacy and an individual in his own right, the silver golem Karn is <mark>haunted</mark> by a single, terrible incident: while serving to protect the young Gerrard, Karn accidentally took the life of another. Wakened from years spent as a statue, the golem has vowed to never kill again as he rejoins Gerrard.", "art": "https://cards.scryfall.io/art_crop/front/8/0/809175d4-115f-4901-9194-766a81a8ccd4.jpg?1782755511"}, {"card": "Glass Asp", "set": "TSP", "html": "Its venom induces a fever that causes its victims to relive the attack in recurring, <mark>haunting</mark> visions.", "art": "https://cards.scryfall.io/art_crop/front/1/1/118253e9-f33a-455d-b785-dd9df657e7cf.jpg?1782716854"}, {"card": "Maeve, Insidious Singer", "set": "GN3", "html": "Her <mark>haunting</mark> tune drowns out the percussion of snapping masts.", "art": "https://cards.scryfall.io/art_crop/front/2/7/2743136b-3610-4c43-8ed7-a00b1f58a874.jpg?1782736572"}, {"card": "Turbulent Moor", "set": "SOC", "html": "&quot;Where others see melancholy, I see promise. All our kindness and cruelty make such <mark>haunting</mark> poetry.&quot;\n—Shadrix Silverquill", "art": "https://cards.scryfall.io/art_crop/front/d/a/da54562d-8c09-4728-bb2b-ae8d464106b8.jpg?1782683343"}, {"card": "Star of Extinction", "set": "CMM", "html": "&quot;The visions <mark>haunt</mark> me. I see the end of the world, brought on by the search for the Immortal Sun.&quot;\n—Shaper Pashona", "art": "https://cards.scryfall.io/art_crop/front/5/2/526d13cb-3616-4ac8-9ac0-04c729d447b2.jpg?1782733128"}, {"card": "Bristlebane Outrider", "set": "ECL", "html": "Memories of oil and blood <mark>haunt</mark> her rides. She patrols kithkin lands driven by the fear of losing another doun.", "art": "https://cards.scryfall.io/art_crop/front/3/8/38b17a3c-4457-47e3-986e-ff0b94c41b1a.jpg?1782683993"}, {"card": "Scared Stiff", "set": "UNF", "html": "The horrors of Sorin&#x27;s <mark>Haunted</mark> Mansion scared Hurrk half to life.", "art": "https://cards.scryfall.io/art_crop/front/d/c/dc479ea0-7c38-49ae-9dc6-1c85183fe6c8.jpg?1782736981"}, {"card": "Agadeem's Awakening // Agadeem, the Undercrypt", "set": "ZNR", "html": "&quot;Now is the death-hour, just before dawn. Wake, sleepers, and <mark>haunt</mark> the living!&quot;\n—Vivias, Witch Vessel\n&quot;Here below the hedron fields, souls and secrets lie entombed.&quot;\n—Vivias, Witch Vessel", "art": "https://cards.scryfall.io/art_crop/front/6/7/67f4c93b-080c-4196-b095-6a120a221988.jpg?1782706316"}, {"card": "Nettle Sentinel", "set": "A25", "html": "Though Shadowmoor&#x27;s monster-<mark>haunted</mark> wilds beckon, she never leaves her post.", "art": "https://cards.scryfall.io/art_crop/front/3/f/3f290ed2-d1a8-4a90-a3a7-8240652dc109.jpg?1782747900"}], "mechanics_snippets": [{"card": "Overwhelmed Archivist // Archive Haunt", "set": "MID", "html": "If Archive <mark>Haunt</mark> would be put into a graveyard from anywhere, exile it instead."}, {"card": "Cry of Contrition", "set": "GPT", "html": "Target player discards a card.\n<mark>Haunt</mark> (When this spell card is put into a graveyard after resolving, exile it <mark>haunting</mark> target creature.)\nWhen the creature this card <mark>haunts</mark> dies, target player discards a card."}, {"card": "Orzhov Pontiff", "set": "2X2", "html": "<mark>Haunt</mark> (When this creature dies, exile it <mark>haunting</mark> target creature.)"}, {"card": "Orzhov Euthanist", "set": "RVR", "html": "<mark>Haunt</mark> (When this creature dies, exile it <mark>haunting</mark> target creature.)\nWhen this creature enters or the creature it <mark>haunts</mark> dies, destroy target creature that was dealt damage this turn."}, {"card": "Benediction of Moons", "set": "GPT", "html": "You gain 1 life for each player.\n<mark>Haunt</mark> (When this spell card is put into a graveyard after resolving, exile it <mark>haunting</mark> target creature.)\nWhen the creature this card <mark>haunts</mark> dies, you gain 1 life for each player."}, {"card": "Graven Dominator", "set": "GPT", "html": "Flying\n<mark>Haunt</mark> (When this creature dies, exile it <mark>haunting</mark> target creature.)\nWhen this creature enters or the creature it <mark>haunts</mark> dies, each other creature has base power and toughness 1/1 until end of turn."}, {"card": "Haunting Misery", "set": "WTH", "html": "As an additional cost to cast this spell, exile X creature cards from your graveyard.\n<mark>Haunting</mark> Misery deals X damage to target player or planeswalker."}, {"card": "Seize the Soul", "set": "GPT", "html": "<mark>Haunt</mark> (When this spell card is put into a graveyard after resolving, exile it <mark>haunting</mark> target creature.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/0/9/099352e2-38c8-4fb4-a25f-6d928aa20f9e.jpg?1782700563", "small": "https://cards.scryfall.io/small/front/0/9/099352e2-38c8-4fb4-a25f-6d928aa20f9e.jpg?1782700563", "card": "Shizo, Death's Storehouse"}}