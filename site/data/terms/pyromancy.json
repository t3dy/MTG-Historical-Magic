romancy/82debe1c-31cb-411f-a353-98a952180666.jpg"}, {"id": "05cae189-f0c5-403b-9216-262ff186c92d", "name": "Pyromancy 101", "set": "MB2", "set_name": "Mystery Booster 2", "released": "2024-08-02", "type_line": "Sorcery — Lesson", "rarity": "rare", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/7/0/70d1834c-c01a-44db-9368-fd285dbf08a7.jpg?1782729306", "img_normal": "https://cards.scryfall.io/normal/front/7/0/70d1834c-c01a-44db-9368-fd285dbf08a7.jpg?1782729306", "scryfall_uri": "https://scryfall.com/card/mb2/566/pyromancy-101?utm_source=api", "local": "img/pyromancy/05cae189-f0c5-403b-9216-262ff186c92d.jpg"}, {"id": "f76bcbfe-483f-4e63-8425-76feca1abf3e", "name": "Pyromancer's Goggles", "set": "FDN", "set_name": "Foundations", "released": "2024-11-15", "type_line": "Legendary Artifact", "rarity": "mythic", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/f/3/f340d8a4-196a-4433-807c-b7124e96e44f.jpg?1782688676", "img_normal": "https://cards.scryfall.io/normal/front/f/3/f340d8a4-196a-4433-807c-b7124e96e44f.jpg?1782688676", "scryfall_uri": "https://scryfall.com/card/fdn/677/pyromancers-goggles?utm_source=api", "local": "img/pyromancy/f76bcbfe-483f-4e63-8425-76feca1abf3e.jpg"}, {"id": "5e78e6e0-60f0-4c3c-b8dd-bd673f5152b8", "name": "Viashino Pyromancer", "set": "FDN", "set_name": "Foundations", "released": "2024-11-15", "type_line": "Creature — Lizard Wizard", "rarity": "common", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/9/f/9f52ada2-cabc-46a3-99df-271833a86909.jpg?1782688715", "img_normal": "https://cards.scryfall.io/normal/front/9/f/9f52ada2-cabc-46a3-99df-271833a86909.jpg?1782688715", "scryfall_uri": "https://scryfall.com/card/fdn/634/viashino-pyromancer?utm_source=api", "local": "img/pyromancy/5e78e6e0-60f0-4c3c-b8dd-bd673f5152b8.jpg"}, {"id": "5fac139a-07d3-4e6c-98e3-d98b199f7a6f", "name": "Young Pyromancer", "set": "TDC", "set_name": "Tarkir: Dragonstorm Commander", "released": "2025-04-11", "type_line": "Creature — Human Shaman", "rarity": "uncommon", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/c/0/c0d74ecd-a595-4012-81b4-083264b40c94.jpg?1782686868", "img_normal": "https://cards.scryfall.io/normal/front/c/0/c0d74ecd-a595-4012-81b4-083264b40c94.jpg?1782686868", "scryfall_uri": "https://scryfall.com/card/tdc/95/young-pyromancer?utm_source=api", "local": "img/pyromancy/5fac139a-07d3-4e6c-98e3-d98b199f7a6f.jpg"}], "flavor_snippets": [{"card": "Geistflame", "set": "DDK", "html": "Innistrad <mark>pyromancers</mark> find their best raw materials in the fury of the dead.", "art": "https://cards.scryfall.io/art_crop/front/c/6/c671b096-17a4-4cdb-b954-7b04981e7aef.jpg?1782751855"}, {"card": "Seismic Strike", "set": "M15", "html": "&quot;Life up here is simple. Adapt to the ways of the mountains and they will reward you. Fight them and they will end you.&quot;\n—Kezim, prodigal <mark>pyromancer</mark>", "art": "https://cards.scryfall.io/art_crop/front/9/7/972d0b03-8602-4ada-86b9-4262941bae67.jpg?1782713140"}, {"card": "Fire Elemental", "set": "FDN", "html": "&quot;The best way to learn from a book on <mark>pyromancy</mark> is to burn it.&quot;\n—Jaya Ballard", "art": "https://cards.scryfall.io/art_crop/front/d/c/dc506f58-048d-49cc-ad8c-2eb851b08bb6.jpg?1782688796"}, {"card": "Incinerating Blast", "set": "FDN", "html": "Most <mark>pyromancers</mark> could never summon the sheer heat necessary to melt solid rock, but most <mark>pyromancers</mark> aren&#x27;t Chandra Nalaar.", "art": "https://cards.scryfall.io/art_crop/front/d/5/d58e20ab-c5ca-4295-884d-78efdaa83243.jpg?1782689186"}, {"card": "Coal Stoker", "set": "DMR", "html": "&quot;The day is mine! I sent three such creatures against my foe, then watched as my magefire popped her soldiers like overripe spleenfruits.&quot;\n—Dobruk the Unstable, <mark>pyromancer</mark>", "art": "https://cards.scryfall.io/art_crop/front/6/7/67c8578e-052f-4182-9bb1-fb35450d22c0.jpg?1782735242"}, {"card": "Insidious Will", "set": "KLD", "html": "&quot;We meet again, <mark>pyromancer</mark>.&quot;\n—Baral, Chief of Compliance", "art": "https://cards.scryfall.io/art_crop/front/8/e/8eafb2bb-58bf-4c6b-ae8f-91bcea12c7d2.jpg?1782711597"}, {"card": "Pyromancer's Assault", "set": "OGW", "html": "Never ask a <mark>pyromancer</mark> if that&#x27;s the best she&#x27;s got.", "art": "https://cards.scryfall.io/art_crop/front/b/2/b2c8dad1-278c-4ced-8124-5593b140d361.jpg?1782712195"}, {"card": "Ghitu Lavarunner", "set": "FDN", "html": "Tolarians teach the theory of <mark>pyromancy</mark>. The Ghitu prefer applied research.", "art": "https://cards.scryfall.io/art_crop/front/8/9/8940d76d-c09f-4d72-a037-439c70ee8d9d.jpg?1782688725"}, {"card": "Panic Attack", "set": "M10", "html": "&quot;What do they see in the throes of panic? I&#x27;m not sure I want to know.&quot;\n—Kezim, prodigal <mark>pyromancer</mark>", "art": "https://cards.scryfall.io/art_crop/front/e/9/e9c6cbc8-e33a-4692-aff0-4de9bb65421d.jpg?1782715724"}, {"card": "Cinder Storm", "set": "A25", "html": "Any <mark>pyromancer</mark> can summon fire with a thought. The trick is putting it out.", "art": "https://cards.scryfall.io/art_crop/front/6/5/650a5856-b8a4-445a-93d2-f3869a03031f.jpg?1782747937"}, {"card": "Puncture Bolt", "set": "SHM", "html": "Cinder <mark>pyromancers</mark> measure their success by counting their enemies&#x27; smoking holes.", "art": "https://cards.scryfall.io/art_crop/front/c/b/cb5a0bc1-ab01-4381-8f54-7381a2213cdf.jpg?1782716153"}, {"card": "Jaya's Immolating Inferno", "set": "CMR", "html": "Centuries ago, a <mark>pyromancer</mark>&#x27;s spark ignited a fiery conflagration.", "art": "https://cards.scryfall.io/art_crop/front/3/6/365336b4-92ee-429d-8f18-4624cba5469d.jpg?1782705837"}, {"card": "Chandra's Ignition", "set": "LCC", "html": "In the moment before her execution, she realized what it meant to be a <mark>pyromancer</mark>, to be alive, to be Chandra.", "art": "https://cards.scryfall.io/art_crop/front/9/6/960f45a3-f9cf-41e6-b813-f3dee620a944.jpg?1782694718"}], "mechanics_snippets": [{"card": "Pyromancy 101", "set": "MB2", "html": "<mark>Pyromancy</mark> 101 deals 1 damage to any target."}, {"card": "Chandra's Outburst", "set": "DOM", "html": "Chandra&#x27;s Outburst deals 4 damage to target player or planeswalker.\nSearch your library and/or graveyard for a card named Chandra, Bold <mark>Pyromancer</mark>, reveal it, and put it into your hand. If you search your library this way, shuffle."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/1/4/1427f615-8430-426e-a669-f9fe12033ac4.jpg?1782737885", "small": "https://cards.scryfall.io/small/front/1/4/1427f615-8430-426e-a669-f9fe12033ac4.jpg?1782737885", "card": "Seasoned Pyromancer"}}