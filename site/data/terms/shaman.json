d2952f77f.jpg?1782731048", "img_normal": "https://cards.scryfall.io/normal/front/5/b/5baeb29b-5462-4692-ba26-844d2952f77f.jpg?1782731048", "scryfall_uri": "https://scryfall.com/card/rvr/230/sunder-shaman?utm_source=api", "local": "img/shaman/38b23fe1-0e76-494a-ad9b-bc22c7d21a5e.jpg"}, {"id": "a1e71473-3eba-4d29-87e2-7f14acab2ccd", "name": "Pyrewild Shaman", "set": "CLU", "set_name": "Ravnica: Clue Edition", "released": "2024-02-23", "type_line": "Creature — Goblin Shaman", "rarity": "uncommon", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/6/0/6037ba46-74ef-4928-9145-180b400d075c.jpg?1782693508", "img_normal": "https://cards.scryfall.io/normal/front/6/0/6037ba46-74ef-4928-9145-180b400d075c.jpg?1782693508", "scryfall_uri": "https://scryfall.com/card/clu/144/pyrewild-shaman?utm_source=api", "local": "img/shaman/a1e71473-3eba-4d29-87e2-7f14acab2ccd.jpg"}, {"id": "fb683e18-50b8-4821-9a1a-86c6dea63ac9", "name": "Temur War Shaman", "set": "DSC", "set_name": "Duskmourn: House of Horror Commander", "released": "2024-09-27", "type_line": "Creature — Human Shaman", "rarity": "rare", "colors": ["G"], "img_small": "https://cards.scryfall.io/small/front/2/4/24824ccd-d470-49eb-a07d-2fc0de817766.jpg?1782689810", "img_normal": "https://cards.scryfall.io/normal/front/2/4/24824ccd-d470-49eb-a07d-2fc0de817766.jpg?1782689810", "scryfall_uri": "https://scryfall.com/card/dsc/200/temur-war-shaman?utm_source=api", "local": "img/shaman/fb683e18-50b8-4821-9a1a-86c6dea63ac9.jpg"}, {"id": "72dc807b-35fb-4d69-ae4c-04eed0646170", "name": "Battle-Rattle Shaman", "set": "FDN", "set_name": "Foundations", "released": "2024-11-15", "type_line": "Creature — Goblin Shaman", "rarity": "uncommon", "colors": ["R"], "img_small": "https://cards.scryfall.io/small/front/f/e/fee05f7e-d4da-4a72-8140-d505eecbdd32.jpg?1782688802", "img_normal": "https://cards.scryfall.io/normal/front/f/e/fee05f7e-d4da-4a72-8140-d505eecbdd32.jpg?1782688802", "scryfall_uri": "https://scryfall.com/card/fdn/533/battle-rattle-shaman?utm_source=api", "local": "img/shaman/72dc807b-35fb-4d69-ae4c-04eed0646170.jpg"}], "flavor_snippets": [{"card": "Ogre Shaman", "set": "TPR", "html": "Ogre <mark>shamans</mark> must be bright enough to learn their invocations and dim enough to use them.", "art": "https://cards.scryfall.io/art_crop/front/e/5/e5e11a62-7885-4494-b128-938485dea8a5.jpg?1782750695"}, {"card": "Sideswipe", "set": "CHK", "html": "Hisoka&#x27;s wizards struggled for years to master the art of redirection that came so naturally to the <mark>shamans</mark> of Ganzan Pass.", "art": "https://cards.scryfall.io/art_crop/front/6/b/6bd611b7-7bd3-4a76-bd69-34a7235965ae.jpg?1782718182"}, {"card": "Orochi Leafcaller", "set": "CHK", "html": "&quot;Only orochi hatched from eggs &#x27;touched by the kami&#x27; may become <mark>shamans</mark>. These days, there are fewer and fewer new <mark>shamans</mark> being born.&quot;", "art": "https://cards.scryfall.io/art_crop/front/f/6/f6c39031-1c49-4c1e-83df-66c3795ddc72.jpg?1782718162"}, {"card": "Sachi, Daughter of Seshiro", "set": "CHK", "html": "&quot;The warriors deal in poison and fangs. We <mark>shamans</mark> remember why our ancestors crawled with their bellies to the earth.&quot;", "art": "https://cards.scryfall.io/art_crop/front/4/c/4c45b36f-b879-417c-b284-0176990fb9f9.jpg?1782718160"}, {"card": "Primal Forcemage", "set": "TSR", "html": "Their calls unheeded by the withered forests, nature <mark>shamans</mark> channeled the life force of their brethren.", "art": "https://cards.scryfall.io/art_crop/front/0/5/0503078a-c5a8-4292-a573-82d062870c7f.jpg?1782741791"}, {"card": "Oxidize", "set": "DST", "html": "&quot;Ashes to ashes, rust to rust.&quot;\n—Viridian <mark>shaman</mark>", "art": "https://cards.scryfall.io/art_crop/front/1/3/1349969e-1cbe-4541-b3ed-154f5a39f1f0.jpg?1782718385"}, {"card": "Skylasher", "set": "DGM", "html": "&quot;It preys on those who would spy on our lands, so we never prey on it.&quot;\n—Kroshkar, Gruul <mark>shaman</mark>", "art": "https://cards.scryfall.io/art_crop/front/4/f/4f4c2069-deb1-4e56-8069-170c4f495944.jpg?1782714014"}, {"card": "Akki Blizzard-Herder", "set": "BOK", "html": "&quot;It remains unclear whether the akki <mark>shamans</mark> could in fact create storms or simply predicted them.&quot;\n—*The History of Kamigawa*", "art": "https://cards.scryfall.io/art_crop/front/7/c/7ce1ee90-67d1-4e83-ae1e-3bd71069aae4.jpg?1782718096"}, {"card": "Rubblebelt Maaka", "set": "RVR", "html": "&quot;The maaka remain loyal to us in this time of strife. We don&#x27;t even have to feed them—our enemies do.&quot;\n—Nedja, Gruul <mark>shaman</mark>", "art": "https://cards.scryfall.io/art_crop/front/8/e/8ead6cd6-12d9-4977-a36a-fab0cc42d0cf.jpg?1782731127"}, {"card": "Labyrinth Minotaur", "set": "ME3", "html": "&quot;I doubt any labyrinth minotaurs still live—but then again, we minotaurs are stubborn beings.&quot;\n—Onatah, Anaba <mark>Shaman</mark>", "art": "https://cards.scryfall.io/art_crop/front/e/5/e5a0658a-dcf6-498f-bac2-da8b3ce5022e.jpg?1782753373"}, {"card": "Stoke the Flames", "set": "MOM", "html": "The Atarka <mark>shamans</mark> roused the fire into a scorching rebuke of the invaders and a beacon of hope for the survivors.", "art": "https://cards.scryfall.io/art_crop/front/0/4/04113b3c-cc8f-4b15-9091-f82ea3df2e7c.jpg?1782697720"}, {"card": "Shrink", "set": "ME2", "html": "&quot;Do not fear adversity. Let your courage be your strength.&quot;\n—Onatah, Anaba <mark>shaman</mark>", "art": "https://cards.scryfall.io/art_crop/front/c/4/c4e319d7-53f3-40e8-9a75-fe1fd8716733.jpg?1782753637"}, {"card": "Burning-Tree Emissary", "set": "2X2", "html": "Those who regard the Gruul as savage simpletons underestimate the subtle power of their <mark>shamans</mark>.", "art": "https://cards.scryfall.io/art_crop/front/b/a/ba327a5e-bd57-4e24-b4b4-062202df30e1.jpg?1782737842"}, {"card": "Spikeshot Goblin", "set": "CMM", "html": "The path of a goblin <mark>shaman</mark> is a journey through a thousand ways of hurting people.", "art": "https://cards.scryfall.io/art_crop/front/a/e/ae922301-181d-4824-802d-e3ba1714cade.jpg?1782733128"}], "mechanics_snippets": [{"card": "Sachi, Daughter of Seshiro", "set": "CHK", "html": "Other Snake creatures you control get +0/+1.\n<mark>Shamans</mark> you control have &quot;{T}: Add {G}{G}.&quot;"}, {"card": "Rebellion of the Flamekin", "set": "LRW", "html": "Whenever you clash, you may pay {1}. If you do, create a 3/1 red Elemental <mark>Shaman</mark> creature token. If you won, that token gains haste until end of turn. (This ability triggers after the clash ends.)"}, {"card": "Velis Vel", "set": "OPCA", "html": "Each creature gets +1/+1 for each other creature on the battlefield that shares at least one creature type with it. (For example, if two Elemental <mark>Shamans</mark> and an Elemental Spirit are on the battlefield, each gets +2/+2.)"}, {"card": "A-Mentor's Guidance", "set": "STX", "html": "When you cast this spell, copy it if you control a planeswalker, Cleric, Druid, <mark>Shaman</mark>, Warlock, or Wizard.\nScry 1, then draw a card."}, {"card": "Harmonic Prodigy", "set": "SOC", "html": "Prowess (Whenever you cast a noncreature spell, this creature gets +1/+1 until end of turn.)\nIf a triggered ability of a <mark>Shaman</mark> or another Wizard you control triggers, that ability triggers an additional time."}, {"card": "Robe of the Archmagi", "set": "CLB", "html": "Whenever equipped creature deals combat damage to a player, you draw that many cards.\nEquip {4}\nEquip <mark>Shaman</mark>, Warlock, or Wizard {1}"}, {"card": "Coat of Arms", "set": "DDS", "html": "Each creature gets +1/+1 for each other creature on the battlefield that shares at least one creature type with it. (For example, if two Goblin Warriors and a Goblin <mark>Shaman</mark> are on the battlefield, each gets +2/+2.)"}, {"card": "Rage Forger", "set": "MOR", "html": "When this creature enters, put a +1/+1 counter on each other <mark>Shaman</mark> creature you control.\nWhenever a creature you control with a +1/+1 counter on it attacks, you may have that creature deal 1 damage to target player or planeswalker."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/0/f/0f342fe9-aa73-4222-b908-d4035b5746be.jpg?1782714344", "small": "https://cards.scryfall.io/small/front/0/f/0f342fe9-aa73-4222-b908-d4035b5746be.jpg?1782714344", "card": "Mindclaw Shaman"}}