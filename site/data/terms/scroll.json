": "2017-10-24", "type_line": "Creature — Merfolk Rogue", "rarity": "common", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/a/7/a7caae7e-9b88-4428-b9e3-86cb8c84bd65.jpg?1782748504", "img_normal": "https://cards.scryfall.io/normal/front/a/7/a7caae7e-9b88-4428-b9e3-86cb8c84bd65.jpg?1782748504", "scryfall_uri": "https://scryfall.com/card/ddt/17/scroll-thief?utm_source=api", "local": "img/scroll/637c5583-4683-4ae4-8b4e-f5da42a772c7.jpg"}, {"id": "f728c4f1-178f-421b-a713-21f85892f051", "name": "Scroll of Avacyn", "set": "JMP", "set_name": "Jumpstart", "released": "2020-07-17", "type_line": "Artifact", "rarity": "common", "colors": [], "img_small": "https://cards.scryfall.io/small/front/2/a/2a2d0981-0af6-42d6-b926-16f8f2327320.jpg?1782706492", "img_normal": "https://cards.scryfall.io/normal/front/2/a/2a2d0981-0af6-42d6-b926-16f8f2327320.jpg?1782706492", "scryfall_uri": "https://scryfall.com/card/jmp/483/scroll-of-avacyn?utm_source=api", "local": "img/scroll/f728c4f1-178f-421b-a713-21f85892f051.jpg"}, {"id": "648bd03d-247e-4d6f-87a9-12a67688cbf5", "name": "Scroll Rack", "set": "CMR", "set_name": "Commander Legends", "released": "2020-11-20", "type_line": "Artifact", "rarity": "mythic", "colors": [], "img_small": "https://cards.scryfall.io/small/front/d/f/dfaaa58d-89bb-4cb3-96a6-b480e6f6954e.jpg?1782705886", "img_normal": "https://cards.scryfall.io/normal/front/d/f/dfaaa58d-89bb-4cb3-96a6-b480e6f6954e.jpg?1782705886", "scryfall_uri": "https://scryfall.com/card/cmr/337/scroll-rack?utm_source=api", "local": "img/scroll/648bd03d-247e-4d6f-87a9-12a67688cbf5.jpg"}, {"id": "aa9a45a5-0250-465b-962e-f2d45dea26f9", "name": "Scroll of Isildur", "set": "LTR", "set_name": "The Lord of the Rings: Tales of Middle-earth", "released": "2023-06-23", "type_line": "Enchantment — Saga", "rarity": "rare", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/1/9/195821f4-ba3d-4412-930f-f3656b319dfd.jpg?1782697208", "img_normal": "https://cards.scryfall.io/normal/front/1/9/195821f4-ba3d-4412-930f-f3656b319dfd.jpg?1782697208", "scryfall_uri": "https://scryfall.com/card/ltr/69/scroll-of-isildur?utm_source=api", "local": "img/scroll/aa9a45a5-0250-465b-962e-f2d45dea26f9.jpg"}, {"id": "0f8b97fe-3e5e-47c2-9a9d-7f77482aa159", "name": "Azami, Lady of Scrolls", "set": "CMM", "set_name": "Commander Masters", "released": "2023-08-04", "type_line": "Legendary Creature — Human Wizard", "rarity": "rare", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/f/a/fa727656-fb33-485b-9378-18b80cad42b9.jpg?1782733258", "img_normal": "https://cards.scryfall.io/normal/front/f/a/fa727656-fb33-485b-9378-18b80cad42b9.jpg?1782733258", "scryfall_uri": "https://scryfall.com/card/cmm/74/azami-lady-of-scrolls?utm_source=api", "local": "img/scroll/0f8b97fe-3e5e-47c2-9a9d-7f77482aa159.jpg"}, {"id": "c15c13d2-8db9-4801-a1f0-f087f2551c92", "name": "Scroll of Fate", "set": "DSC", "set_name": "Duskmourn: House of Horror Commander", "released": "2024-09-27", "type_line": "Artifact", "rarity": "rare", "colors": [], "img_small": "https://cards.scryfall.io/small/front/4/7/476d509f-efc0-4138-8dce-23fa6321279c.jpg?1782689765", "img_normal": "https://cards.scryfall.io/normal/front/4/7/476d509f-efc0-4138-8dce-23fa6321279c.jpg?1782689765", "scryfall_uri": "https://scryfall.com/card/dsc/251/scroll-of-fate?utm_source=api", "local": "img/scroll/c15c13d2-8db9-4801-a1f0-f087f2551c92.jpg"}, {"id": "cef5361a-a189-4e05-a8b8-fc764aed73b9", "name": "All-Fates Scroll", "set": "EOE", "set_name": "Edge of Eternities", "released": "2025-08-01", "type_line": "Artifact", "rarity": "uncommon", "colors": [], "img_small": "https://cards.scryfall.io/small/front/3/a/3a5ed010-cb17-45df-b169-ebc807dae534.jpg?1782685422", "img_normal": "https://cards.scryfall.io/normal/front/3/a/3a5ed010-cb17-45df-b169-ebc807dae534.jpg?1782685422", "scryfall_uri": "https://scryfall.com/card/eoe/234/all-fates-scroll?utm_source=api", "local": "img/scroll/cef5361a-a189-4e05-a8b8-fc764aed73b9.jpg"}, {"id": "882d032b-db36-401a-8075-a9fabc90c53d", "name": "Waterbending Scroll", "set": "TLA", "set_name": "Avatar: The Last Airbender", "released": "2025-11-21", "type_line": "Artifact", "rarity": "uncommon", "colors": ["U"], "img_small": "https://cards.scryfall.io/small/front/5/0/50d0be73-a2c8-44a0-9178-9949f342f6f9.jpg?1782684614", "img_normal": "https://cards.scryfall.io/normal/front/5/0/50d0be73-a2c8-44a0-9178-9949f342f6f9.jpg?1782684614", "scryfall_uri": "https://scryfall.com/card/tla/81/waterbending-scroll?utm_source=api", "local": "img/scroll/882d032b-db36-401a-8075-a9fabc90c53d.jpg"}], "flavor_snippets": [{"card": "Brawn", "set": "MOC", "html": "&quot;&#x27;I have arrived,&#x27; bellowed Brawn, and the plane shuddered.&quot;\n—*<mark>Scroll</mark> of Beginnings*", "art": "https://cards.scryfall.io/art_crop/front/8/c/8c05568e-fa50-46e9-aec4-1ba5e814029e.jpg?1782697938"}, {"card": "Auriok Transfixer", "set": "MRD", "html": "&quot;My grandfather knew enough spells to fill a hundred <mark>scrolls</mark>. Nowadays, if a spell cannot fight the levelers, it is not even taught to our young.&quot;", "art": "https://cards.scryfall.io/art_crop/front/9/f/9f5c3f22-f228-4503-9d35-ee1b36a46ef0.jpg?1782718553"}, {"card": "Wonder", "set": "TDC", "html": "&quot;The awestruck birds gazed at Wonder. Slowly, timidly, they rose into the air.&quot;\n—*<mark>Scroll</mark> of Beginnings*", "art": "https://cards.scryfall.io/art_crop/front/5/6/567abd78-d4a3-4a33-9b5b-b5ca361059cc.jpg?1782686807"}, {"card": "Ardent Dustspeaker", "set": "STX", "html": "&quot;The Founder Dragons weren&#x27;t even hatched when this <mark>scroll</mark> was written!&quot;", "art": "https://cards.scryfall.io/art_crop/front/7/f/7ff4832a-26c0-4da5-abbb-1941e7084e72.jpg?1782704957"}, {"card": "Glory", "set": "DMR", "html": "&quot;Glory was gone; Glory was everywhere.&quot;\n—*<mark>Scroll</mark> of Beginnings*", "art": "https://cards.scryfall.io/art_crop/front/6/b/6b01ebcf-8451-486e-84f6-8e6e1bb9d6e3.jpg?1782735319"}, {"card": "Krosan Grip", "set": "C21", "html": "&quot;Give up these unnatural weapons, these <mark>scrolls</mark>. Heart and mind and fist are enough.&quot;\n—Zyd, Kamahlite druid", "art": "https://cards.scryfall.io/art_crop/front/d/3/d3571dee-7b90-4c0c-abc7-59b515ffa129.jpg?1782705190"}, {"card": "Quiet Purity", "set": "CHK", "html": "&quot;When the Kami of Utter Silence passes, walls lose their secrets. <mark>Scrolls</mark> lose their lessons. Tapestries lose their beauty. Where there was meaning, there is only stillness.&quot;\n—Sensei Hisoka", "art": "https://cards.scryfall.io/art_crop/front/e/c/ecd4d7cd-12a9-49f2-912d-2a6024112d13.jpg?1782718251"}, {"card": "Filth", "set": "JUD", "html": "&quot;As the portal closed, Filth oozed through. The stench of evil followed it in.&quot;\n—*<mark>Scroll</mark> of Beginnings*", "art": "https://cards.scryfall.io/art_crop/front/3/7/37de06dc-c0c1-4edb-9732-2d16dbabfb31.jpg?1782719246"}, {"card": "Courier's Capsule", "set": "ALA", "html": "In ages past, Esper couriers bore messages written on ornate <mark>scrolls</mark>. The medium has grown more sophisticated, but the principle remains the same.", "art": "https://cards.scryfall.io/art_crop/front/3/9/39ae12ff-8039-4aac-aa50-f879376888a1.jpg?1782715984"}, {"card": "Psionic Gift", "set": "ODY", "html": "For sale: Complete wizard&#x27;s library. Rare <mark>scrolls</mark>, grimoires, and works of ancient spellcrafting! Slightly abridged.", "art": "https://cards.scryfall.io/art_crop/front/8/6/862fc18f-90d2-430d-aff2-47c1483dee9d.jpg?1782719416"}, {"card": "Merchant Scroll", "set": "8ED", "html": "Lat-Nam wizards trade knowledge on <mark>scrolls</mark> made of magic so they can better guard against thieves and spies.", "art": "https://cards.scryfall.io/art_crop/front/b/b/bb5385d2-ca5d-4fb9-934b-b7cc8b38ac89.jpg?1782718846"}, {"card": "Brush Off", "set": "SOS", "html": "&quot;You&#x27;re the one who brought a priceless <mark>scroll</mark> to a duel!&quot;", "art": "https://cards.scryfall.io/art_crop/front/1/5/151eab82-d20f-433b-b3bb-1d44e2871d5c.jpg?1782683003"}, {"card": "Waterbending Scroll", "set": "TLA", "html": "The <mark>scroll</mark> taught Katara many useful skills. So did fighting the angry pirates she stole it from.", "art": "https://cards.scryfall.io/art_crop/front/5/0/50d0be73-a2c8-44a0-9178-9949f342f6f9.jpg?1782684614"}, {"card": "Mikokoro, Center of the Sea", "set": "DMC", "html": "&quot;Center of the Sea, Eye of the World, Shrine of Enlightenment. Seek it for answers. Seek it for healing. Seek it and return transformed.&quot;\n—<mark>Scroll</mark> fragment from the ruins of Minamo", "art": "https://cards.scryfall.io/art_crop/front/d/8/d80eb098-5433-4b1e-aad5-0fd31bf598dd.jpg?1782700573"}], "mechanics_snippets": [{"card": "Ulgrotha Charm", "set": "UNK", "html": "Choose one —\n• Merchant <mark>Scroll</mark> (Search for a blue instant.)\n• Memory Lapse (Counter a spell and put it on top of its owner&#x27;s library.)\n• Forget (Target player discards 2, then draws that many.)"}, {"card": "Ignacio of Myra's Marvels", "set": "UNF", "html": "As Ignacio of Myra&#x27;s Marvels enters, choose armor, blood, book, bottle, fang, fire, <mark>scroll</mark>, spear, sword, or water."}, {"card": "Scavenger Hunt", "set": "UNF", "html": "Visit — Choose &quot;a creature wearing a hat,&quot; &quot;a book or <mark>scroll</mark>,&quot; or &quot;teeth&quot; at random. You have ten seconds to search your library and reveal a card with the chosen item in its art. If you do, claim the prize! Then shuffle."}, {"card": "Aretopolis", "set": "OPCA", "html": "When you planeswalk to Aretopolis and at the beginning of your upkeep, put a <mark>scroll</mark> counter on Aretopolis, then you gain life equal to the number of <mark>scroll</mark> counters on it."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/8/c/8c05568e-fa50-46e9-aec4-1ba5e814029e.jpg?1782697938", "small": "https://cards.scryfall.io/small/front/8/c/8c05568e-fa50-46e9-aec4-1ba5e814029e.jpg?1782697938", "card": "Brawn"}}