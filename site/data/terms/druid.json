ors": ["G", "R"], "img_small": "https://cards.scryfall.io/small/front/b/8/b82d8359-4841-478c-851b-13a1a0f94737.jpg?1782711373", "img_normal": "https://cards.scryfall.io/normal/front/b/8/b82d8359-4841-478c-851b-13a1a0f94737.jpg?1782711373", "scryfall_uri": "https://scryfall.com/card/c16/232/zhur-taa-druid?utm_source=api", "local": "img/druid/5979310e-38c8-489f-ab9e-2723af98a3a5.jpg"}], "flavor_snippets": [{"card": "Terrus Wurm", "set": "RTR", "html": "&quot;We follow it through its tunnels, and where it dies, we farm.&quot;\n—Mihas, spore <mark>druid</mark>", "art": "https://cards.scryfall.io/art_crop/front/1/9/1998135c-7b7f-402b-a8a5-4f4af131b1bc.jpg?1782714254"}, {"card": "Kaysa", "set": "ME2", "html": "Kaysa speaks as the elder <mark>druid</mark>, but Yavimaya recognizes only one voice: its own.", "art": "https://cards.scryfall.io/art_crop/front/8/e/8e04a31e-24b6-4d54-90c3-3f37d457131b.jpg?1782753638"}, {"card": "Spellwild Ouphe", "set": "FUT", "html": "&quot;You&#x27;d think that their big glowing eyes would be almost hypnotic to look at. In fact, it&#x27;s the other way around—they are entranced by nearly everything they see.&quot;\n—Balecki, Spellwild <mark>druid</mark>", "art": "https://cards.scryfall.io/art_crop/front/2/3/231eb017-2945-4915-8032-c09894e88d49.jpg?1782716656"}, {"card": "Ground Seal", "set": "C18", "html": "&quot;Let all we have buried be buried forever.&quot;\n—Seton, centaur <mark>druid</mark>", "art": "https://cards.scryfall.io/art_crop/front/c/4/c4e9995e-f26b-4638-b69d-a310f58f0331.jpg?1782709304"}, {"card": "Krosan Wayfarer", "set": "JUD", "html": "&quot;The Krosan Forest lives, and <mark>druids</mark> are its seeds.&quot;\n—Seton, centaur <mark>druid</mark>", "art": "https://cards.scryfall.io/art_crop/front/5/3/5356e684-c2fc-465e-a16c-7300824d2a8d.jpg?1782719223"}, {"card": "Circle of Dreams Druid", "set": "AFR", "html": "The realms protected by <mark>druids</mark> of the Circle of Dreams are gleaming, fruitful places, where dream and reality blur together and the weary can find rest.", "art": "https://cards.scryfall.io/art_crop/front/b/e/be6fdec0-a2c4-4da2-ae14-961185eaee66.jpg?1782704338"}, {"card": "Fang Guardian", "set": "DFT", "html": "Though the Fang <mark>Druids</mark> desired peace, the Grand Prix&#x27;s interference threatened to awaken old dangers on Muraganda.", "art": "https://cards.scryfall.io/art_crop/front/6/d/6db483a7-c9f0-449d-be97-77dbd6d3a27a.jpg?1782687833"}, {"card": "Krosan Druid", "set": "DOM", "html": "&quot;<mark>Druids</mark> endure disaster as seeds endure winter. Now Krosa blooms once more.&quot;", "art": "https://cards.scryfall.io/art_crop/front/c/3/c332dc82-7664-44d0-b92a-a3d867399884.jpg?1782710095"}, {"card": "Plow Under", "set": "8ED", "html": "To renew the land, plow the land.\nTo destroy the land, do nothing.\n—<mark>Druids</mark>&#x27; saying", "art": "https://cards.scryfall.io/art_crop/front/2/7/27128f26-0d89-4962-96e8-5fa343031a26.jpg?1782718648"}, {"card": "Into the North", "set": "CSP", "html": "&quot;Our border lands fall under the grip of Heidar&#x27;s second winter. Go forth and reclaim them for Yavimaya.&quot;\n—Kaysa, elder <mark>druid</mark> of the Juniper Order", "art": "https://cards.scryfall.io/art_crop/front/7/9/79cea55d-8ef3-44a5-894e-967f1e97fc02.jpg?1782717026"}, {"card": "Vexing Beetle", "set": "LGN", "html": "As the Mirari&#x27;s mutating effects grew out of control, centaurs and <mark>druids</mark> fled—but insects swarmed closer.", "art": "https://cards.scryfall.io/art_crop/front/d/5/d599d35f-1b73-498b-9a21-831c908a95d8.jpg?1782719015"}, {"card": "Wayfarer's Bauble", "set": "TDC", "html": "<mark>Druids</mark> hold certain plants to be sacred and use their leaves and wood as a spellcasting focus.", "art": "https://cards.scryfall.io/art_crop/front/a/c/ac1960a1-9141-468c-b96c-6c8e6905084d.jpg?1782686666"}, {"card": "Reiterate", "set": "TSR", "html": "&quot;Echoes of the Mirari&#x27;s power yet linger.&quot;\n—Zyd, Kamahlite <mark>druid</mark>", "art": "https://cards.scryfall.io/art_crop/front/9/9/99302c41-434f-41ff-a61a-2c3681a0c135.jpg?1782741820"}, {"card": "Fowl Strike", "set": "MH3", "html": "With a resounding wallop, the ancient battle between buzzard and <mark>druid</mark> was finally finished.", "art": "https://cards.scryfall.io/art_crop/front/8/3/83b6c7ab-f42f-40d2-9cb6-89291d57e27f.jpg?1782691261"}], "mechanics_snippets": [{"card": "Gilt-Leaf Archdruid", "set": "MOR", "html": "Whenever you cast a <mark>Druid</mark> spell, you may draw a card.\nTap seven untapped <mark>Druids</mark> you control: Gain control of all lands target player controls."}, {"card": "Lukamina, Moon Druid", "set": "HBG", "html": "Wild Shape — Specialize {3}. Activate only if you control six or more lands.\nWhen Lukamina, Moon <mark>Druid</mark> enters, if you cast it, seek a land card with a basic land type."}, {"card": "A-Mentor's Guidance", "set": "STX", "html": "When you cast this spell, copy it if you control a planeswalker, Cleric, <mark>Druid</mark>, Shaman, Warlock, or Wizard.\nScry 1, then draw a card."}, {"card": "Seton, Krosan Protector", "set": "ODY", "html": "Tap an untapped <mark>Druid</mark> you control: Add {G}."}, {"card": "Deeproot Historian", "set": "LCC", "html": "Merfolk and <mark>Druid</mark> cards in your graveyard have retrace. (You may cast cards with retrace from your graveyard by discarding a land card in addition to paying their other costs.)"}, {"card": "Freyalise, Llanowar's Fury", "set": "CMM", "html": "+2: Create a 1/1 green Elf <mark>Druid</mark> creature token with &quot;{T}: Add {G}.&quot;\n−2: Destroy target artifact or enchantment.\n−6: Draw a card for each green creature you control.\nFreyalise, Llanowar&#x27;s Fury can be your commander."}, {"card": "Teval's Judgment", "set": "TDC", "html": "Whenever one or more cards leave your graveyard, choose one that hasn&#x27;t been chosen this turn —\n• Draw a card.\n• Create a Treasure token.\n• Create a 2/2 black Zombie <mark>Druid</mark> creature token."}, {"card": "Fanatic of Rhonas", "set": "MH3", "html": "Eternalize {2}{G}{G} ({2}{G}{G}, Exile this card from your graveyard: Create a token that&#x27;s a copy of it, except it&#x27;s a 4/4 black Zombie Snake <mark>Druid</mark> with no mana cost. Eternalize only as a sorcery.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/1/9/19ca91ea-dffd-44a9-a54a-c664d83c357b.jpg?1782709519", "small": "https://cards.scryfall.io/small/front/1/9/19ca91ea-dffd-44a9-a54a-c664d83c357b.jpg?1782709519", "card": "Druid of Horns"}}