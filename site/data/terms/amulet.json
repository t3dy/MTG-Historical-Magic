front/b/a/babf0f59-0199-4dba-a149-f62261115f5e.jpg?1782682039", "scryfall_uri": "https://scryfall.com/card/msc/736/white-tiger-amulet-keeper?utm_source=api", "local": "img/amulet/0fa01155-638d-44ed-8963-46b202b0e720.jpg"}], "flavor_snippets": [{"card": "Traveler's Amulet", "set": "INR", "html": "The rider set off into the eerie mist, swaddled in armor and laden with <mark>amulets</mark>.", "art": "https://cards.scryfall.io/art_crop/front/2/6/26a7e5f0-0d60-4118-ad10-b27c7382511a.jpg?1782726659"}, {"card": "Amulet of Kroog", "set": "ME4", "html": "Among the first allies Urza gained were the people of Kroog. As a sign of friendship, Urza gave the healers of the city potent <mark>amulets</mark>; afterwards, thousands journeyed to Kroog in hope of healing, greatly adding to the city&#x27;s glory.", "art": "https://cards.scryfall.io/art_crop/front/5/5/55540bd5-e0aa-40aa-8b98-2dfb4762b498.jpg?1782752699"}, {"card": "Sun Clasp", "set": "DMR", "html": "&quot;Open when darkness threatens.&quot;\n—<mark>Amulet</mark> inscription", "art": "https://cards.scryfall.io/art_crop/front/4/9/49e33908-cf4f-45b4-8d97-a117308187f7.jpg?1782735301"}, {"card": "Quicksilver Amulet", "set": "M12", "html": "Those who examine the <mark>amulet</mark> too closely have been known to become part of its ornate carvings.", "art": "https://cards.scryfall.io/art_crop/front/0/4/04c0357a-e98d-4c49-83ad-d7a8ebe7e2d1.jpg?1782714852"}, {"card": "Treasured Find", "set": "DDM", "html": "Gorgons crave beautiful things: gems, exquisite <mark>amulets</mark>, the alabaster corpses of the petrified dead . . .", "art": "https://cards.scryfall.io/art_crop/front/9/3/9317b616-eabe-461a-bd60-6dd8620becb4.jpg?1782751524"}], "mechanics_snippets": [{"card": "Primal Amulet // Primal Wellspring", "set": "XLN", "html": "(Transforms from Primal <mark>Amulet</mark>.)"}, {"card": "You Line Up the Shot", "set": "HBG", "html": "Choose one —\n• Aim for the Wyvern — Conjure a card named Plummet into your hand.\n• Aim for the Cursed <mark>Amulet</mark> — Conjure a card named Naturalize into your hand.\n• Fire a Warning Shot — Draw a card."}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/a/b/ab8b1ec2-9303-4722-8644-b3bc1a5c387f.jpg?1782705515", "small": "https://cards.scryfall.io/small/front/a/b/ab8b1ec2-9303-4722-8644-b3bc1a5c387f.jpg?1782705515", "card": "Giant's Amulet"}}