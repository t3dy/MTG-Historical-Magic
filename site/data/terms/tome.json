ards.scryfall.io/art_crop/front/f/3/f3969cc7-92b9-45cd-9a4f-d94c2178a04d.jpg?1782716674"}, {"card": "Retrieval Agent", "set": "BRO", "html": "The humming <mark>tome</mark> burned his leather glove, nearly taking his hand along with it. Then a strange power coursed through him.", "art": "https://cards.scryfall.io/art_crop/front/f/3/f333a7b1-936e-42f3-ba22-2c76dd2f1c9a.jpg?1782699816"}, {"card": "My First Tome", "set": "UNH", "html": "This card is named My First <mark>Tome</mark>.", "art": "https://cards.scryfall.io/art_crop/front/e/5/e56ccbd2-c17d-4625-bc11-181d36a84936.jpg?1782754064"}, {"card": "Enthusiastic Study", "set": "STX", "html": "&quot;If the pen is mightier than the sword, just think what a giant <mark>tome</mark> could do!&quot;", "art": "https://cards.scryfall.io/art_crop/front/5/4/543c64ff-2c51-4a63-a940-dc8645717c85.jpg?1782704953"}, {"card": "Phyrexian Censor", "set": "MOM", "html": "Quintorius muffled a sob as he watched the thing that was once Professor Pitnik &quot;confiscate&quot; yet another priceless historical <mark>tome</mark>.", "art": "https://cards.scryfall.io/art_crop/front/1/5/150e17b1-b9fd-4ec4-b305-19596fed14d1.jpg?1782697808"}, {"card": "Two-Headed Zombie", "set": "M19", "html": "&quot;Thread the torsos together with angel hair to ensure they will cooperate in battle.&quot;\n—*The Stitcher&#x27;s <mark>Tome</mark>*", "art": "https://cards.scryfall.io/art_crop/front/2/c/2cc5760e-8b27-4d37-9772-c9eda90b1d95.jpg?1782709559"}, {"card": "Candles of Leng", "set": "TSP", "html": "&quot;A <mark>tome</mark> stored in its light is as crisp as the day it was written.&quot;\n—Ettovard, Tolarian archivist", "art": "https://cards.scryfall.io/art_crop/front/e/e/ee874779-e654-48f0-8f2d-cc98ef150d75.jpg?1782716830"}, {"card": "Primeval Light", "set": "GPT", "html": "&quot;Look to the old <mark>tomes</mark>, those bound in hides and written in yarberry ink. They hold the spells that can free us of the clutter of modern magecraft.&quot;\n—Dravash, dowsing shaman", "art": "https://cards.scryfall.io/art_crop/front/2/9/293ce819-c228-4ff1-827c-3d0cbed703ea.jpg?1782717281"}, {"card": "Dutiful Knowledge Seeker", "set": "TLE", "html": "Wan Shi Tong rewards those who provide rare and insightful <mark>tomes</mark>.", "art": "https://cards.scryfall.io/art_crop/front/3/3/332914f3-9c79-4f76-882e-f72e42681d21.jpg?1782724388"}, {"card": "Gore Vassal", "set": "MBS", "html": "&quot;Rid them of their unfaithful organs. Bring new hearts to the unbelievers.&quot;\n—*<mark>Tome</mark> of Machines*, verse 1703", "art": "https://cards.scryfall.io/art_crop/front/c/2/c2889bba-58a8-46e1-959c-0fd38c1732f9.jpg?1782715252"}, {"card": "Waterlogged Teachings // Inundated Archive", "set": "MH3", "html": "The long-dead librarians are still on hand to recommend selected titles.\nMoldering <mark>tomes</mark> line rotting shelves. Generations of priceless knowledge fade from memory beneath the waves.", "art": "https://cards.scryfall.io/art_crop/front/0/6/060f9675-4921-4cbb-bae2-54c85c679fd4.jpg?1782691144"}, {"card": "Thoughtbind", "set": "CHK", "html": "&quot;As the rest of the mortal world waged war, Lady Azami and her students invaded <mark>tomes</mark> of knowledge. Their search yielded spells critical in the fight.&quot;\n—*Observations of the Kami War*", "art": "https://cards.scryfall.io/art_crop/front/7/9/7919cf41-67bb-4dc4-90de-cf3fa2096c2e.jpg?1782718223"}, {"card": "Candlekeep Sage", "set": "CLB", "html": "You love the smell of dusty <mark>tomes</mark>, the flicker of candles during late-night reading, and the old texts that bring to life the scholars who have come before.", "art": "https://cards.scryfall.io/art_crop/front/6/f/6f706ac3-0ad8-44ac-a99e-21c04075951d.jpg?1782701315"}, {"card": "Arcane Epiphany", "set": "FDN", "html": "For years, the <mark>tome</mark> pulsed with forgotten spells and secrets, hungry for a mind strong enough to read it.", "art": "https://cards.scryfall.io/art_crop/front/0/6/06431793-5dfe-4cbf-990b-4bcc960d1f31.jpg?1782689239"}], "mechanics_snippets": [{"card": "Tome of Gadwick", "set": "YWOE", "html": "Equipped creature gets +1/+0 and has ward {1}.\nWhenever equipped creature attacks, conjure a random card from <mark>Tome</mark> of Gadwick&#x27;s spellbook into your hand.\nEquip {1}"}, {"card": "Tome of the Infinite", "set": "J21", "html": "{U}, {T}: Conjure a random card from <mark>Tome</mark> of the Infinite&#x27;s spellbook into your hand. It perpetually gains &quot;You may spend mana as though it were mana of any color to cast this spell.&quot;"}, {"card": "A-Tome Shredder", "set": "STX", "html": "Haste\n{T}, Exile an instant or sorcery card from your graveyard: Put a +1/+1 counter on <mark>Tome</mark> Shredder."}, {"card": "Tome Blast", "set": "SOS", "html": "<mark>Tome</mark> Blast deals 2 damage to any target.\nFlashback {4}{R} (You may cast this card from your graveyard for its flashback cost. Then exile it.)"}], "thumb": {"art": "https://cards.scryfall.io/art_crop/front/f/3/f3969cc7-92b9-45cd-9a4f-d94c2178a04d.jpg?1782716674", "small": "https://cards.scryfall.io/small/front/f/3/f3969cc7-92b9-45cd-9a4f-d94c2178a04d.jpg?1782716674", "card": "Flowstone Embrace"}}